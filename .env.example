# PackersHub — Environment Variables
#
# Copy this file to `.env` for local dev (wrangler pages dev reads `.env`
# automatically). For production, set each of these as a Cloudflare Pages
# secret instead — never commit real values to git:
#
#   wrangler pages secret put GOOGLE_REVIEW_URL --project-name=packershub
#   wrangler pages secret put CRON_SECRET --project-name=packershub
#   ...repeat for each variable below that you actually use.
#
# Every integration in this codebase is written to no-op gracefully if its
# variable is missing, so you do NOT need to fill in all of these to deploy —
# only the ones for features you want active. Leave the rest blank/unset.

# ── Lead notifications & follow-up sequence (src/pages/api/follow-up.ts) ──
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
WABA_TOKEN=
WABA_PHONE_NUMBER_ID=
WABA_TEMPLATE_FOLLOWUP=
TEAM_PHONE=

# ── Google review request step (src/pages/api/follow-up.ts) ──────────────
# Your Google Business Profile review link. Get it from:
# Google Business Profile → "Get more reviews" → copy the short link
# (looks like https://g.page/r/XXXXXXXXXXXX/review)
GOOGLE_REVIEW_URL=

# ── Cron endpoint protection (src/pages/api/follow-up-cron.ts) ───────────
# Any long random string. Required if you expose /api/follow-up-cron to an
# external cron service (cron-job.org, Render cron, etc.) — without this set,
# the endpoint is unprotected and callable by anyone who finds the URL.
CRON_SECRET=

# ── AI Phone Agent / chat (src/pages/api/chat.ts) ─────────────────────────
ANTHROPIC_API_KEY=

# ── Search Console indexing notifications (src/pages/api/index-notify.ts) ─
GOOGLE_SA_EMAIL=
GOOGLE_SA_KEY=

# ── Auto-index protection (optional, recommended) ─────────────────────────
# Locks down /api/index-notify so only your GitHub Actions workflow (and
# you, via /admin/index-ping/) can trigger Google indexing calls.
# Set the SAME value in two places:
#   1. Cloudflare Pages → Settings → Environment variables → AUTO_INDEX_TOKEN
#   2. GitHub repo → Settings → Secrets and variables → Actions →
#      New repository secret → name it AUTO_INDEX_TOKEN
# Leave both unset and the endpoint stays open (works, just unprotected).
AUTO_INDEX_TOKEN=

# ── Site URL used for absolute links in emails / schema ───────────────────
SITE_URL=https://packershub.in
