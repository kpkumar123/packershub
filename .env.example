# PackersHub Environment Variables
# Copy to .env and fill in your values

# Anthropic API for AI Chatbot
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Site
PUBLIC_SITE_URL=https://www.packershub.in
PUBLIC_PHONE=+917731074075
PUBLIC_WHATSAPP=917731074075

# ── Analytics (v6.5.0) ──────────────────────────────────────────
# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX
# Get one free at analytics.google.com → Admin → Create Property.
# Leave blank and the site simply skips analytics — nothing breaks.
PUBLIC_GA_MEASUREMENT_ID=

# ── Lead-Capture Backup Email (v6.5.0) ──────────────────────────
# Optional. Sends an email notification for every form submission as a
# second backup alongside WhatsApp. Free tier at resend.com is enough
# to start. Leave both blank to skip — KV/WhatsApp still work.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=

# ── Order Tracking / Admin (v6.5.0) ──────────────────────────────
# Shared secret for the staff-only /admin/orders/ page. Make this a
# long random string — anyone with it can update booking statuses.
ADMIN_TOKEN=

# Note: TRACKING_KV (the actual order database) is a Cloudflare KV
# namespace binding, not an env var — it's configured in wrangler.toml.
# See SETUP_NEW_FEATURES.md for the one-time setup steps.
