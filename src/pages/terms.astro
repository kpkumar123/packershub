---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Terms & Conditions — PackersHub"
  description="PackersHub Terms and Conditions — Service terms, payment, liability, insurance, cancellation policy."
  canonical="https://www.packershub.in/terms"
>
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-brand-grey" role="list">
          <li><a href="/" class="hover:text-brand-orange">Home</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-brand-orange font-semibold" aria-current="page">Terms & Conditions</li>
        </ol>
      </nav>
      <h1 class="font-display font-extrabold text-4xl text-brand-dark mb-4">Terms &amp; Conditions</h1>
      <p class="text-brand-grey mb-8"><time datetime="2025-01-01">Last updated: January 1, 2025</time></p>
      <div class="prose prose-lg max-w-none text-brand-grey">
        <h2>1. Service Agreement</h2>
        <p>By booking PackersHub services, you agree to these terms. Services include packing, transport, storage, and related moving services across South India.</p>
        <h2>2. Pricing & Payment</h2>
        <p>All quotes are valid for 7 days. Final charges may vary based on actual goods volume. GST applicable at prevailing rates. Payment accepted: Cash, UPI, NEFT, Card.</p>
        <h2>3. Insurance & Liability</h2>
        <p>All shipments include basic transit insurance. Claims must be reported within 24 hours of delivery. Maximum liability limited to declared value of goods.</p>
        <h2>4. Cancellation Policy</h2>
        <p>Cancellation 7+ days before move: full refund. 3–7 days: 50% refund. Under 3 days: no refund. Force majeure events: full credit note issued.</p>
        <h2>5. Contact</h2>
        <p>Questions: <a href="mailto:info@packershub.in" class="text-brand-orange">info@packershub.in</a> · <a href="tel:+917731074075" class="text-brand-orange">+91 77310 74075</a></p>
      </div>
    </div>
  </section>
</BaseLayout>
