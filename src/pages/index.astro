---
import BaseLayout from '../layouts/BaseLayout.astro';
import statesData from '../data/states.json';
import citiesData from '../data/cities.json';
import BookingEngine from '../components/BookingEngine.astro';

const topCities = citiesData.filter(c =>
  ['visakhapatnam','vijayawada','guntur','nellore','hyderabad','chennai','bengaluru','kochi','coimbatore','madurai'].includes(c.slug)
);

const services = [
  { icon: '🏠', title: 'House Shifting', desc: 'Complete home relocation — packing, loading, transport, unpacking. Every item handled with care.', link: '/services/' },
  { icon: '🏢', title: 'Office Relocation', desc: 'Zero-downtime office moves with secure IT handling, document management, and weekend scheduling.', link: '/services/' },
  { icon: '🛵', title: 'Bike Transport', desc: 'Cradle-mounted two-wheeler transport with scratch protection across all 100 cities.', link: '/services/' },
  { icon: '🚗', title: 'Car Carrier Service', desc: 'Open and enclosed car transport — city-to-city or interstate, with full insurance coverage.', link: '/services/' },
  { icon: '📦', title: 'Warehouse Storage', desc: 'Secure climate-controlled storage. First 48 hours free. Extended options available.', link: '/services/' },
  { icon: '🚚', title: 'Intercity Moves', desc: 'Transparent all-inclusive pricing for moves between any of our 100 South Indian cities.', link: '/services/' },
];

const testimonials = [
  { name: 'Ramesh K.', city: 'Hyderabad → Bengaluru', text: 'PackersHub handled our 3 BHK move perfectly. Transparent pricing, punctual crew, zero damage. Exactly what they promised.', stars: 5, date: 'March 2026' },
  { name: 'Priya S.', city: 'Chennai → Kochi', text: 'Booked through WhatsApp, got confirmation in 20 minutes. The team packed everything professionally. Highly recommend.', stars: 5, date: 'April 2026' },
  { name: 'Venkat R.', city: 'Vijayawada → Hyderabad', text: 'Office relocation of 25 workstations done over the weekend. Zero downtime Monday. Exceptional service.', stars: 5, date: 'February 2026' },
];

const faqs = [
  { q: 'How much does house shifting cost with PackersHub?', a: 'Pricing depends on distance, volume of goods, and specific requirements. We provide free, all-inclusive quotes after a proper survey — call or WhatsApp +91 77310 74075 for your personalised estimate.' },
  { q: 'What cities do you serve?', a: 'PackersHub serves 100 cities across 5 South Indian states: Andhra Pradesh, Telangana, Tamil Nadu, Karnataka, and Kerala. See our state pages for the complete city list.' },
  { q: 'Is goods-in-transit insurance included?', a: 'Yes. Every PackersHub consignment includes goods-in-transit insurance as standard — not as an add-on. Your belongings are protected from pickup to delivery.' },
  { q: 'How far in advance should I book?', a: 'For local moves, 3–5 days ahead is usually sufficient. For interstate moves or moves during peak periods (academic year transitions, festive seasons), 1–2 weeks ahead ensures crew and vehicle availability.' },
  { q: 'Do you charge for stairs or narrow lanes?', a: 'No. Our all-inclusive quotes cover all standard moving scenarios including stairs, elevators, and narrow access roads. You pay exactly what was quoted.' },
  { q: 'Can I get a quote without an in-person visit?', a: 'Yes. We offer video survey quotes for all cities in our network. Call or WhatsApp +91 77310 74075 and share details about your move.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const stats = [
  { num: '100+', label: 'Cities Served' },
  { num: '5', label: 'States Covered' },
  { num: '₹0', label: 'Hidden Charges' },
  { num: '24/7', label: 'Customer Support' },
];

const stateEmojis = ['🌊','💎','🏛️','☕','🌴'];
---
<BaseLayout
  title="PackersHub — Packers and Movers Across South India | 100 Cities"
  description="PackersHub: trusted packers and movers across 100 cities in Andhra Pradesh, Telangana, Tamil Nadu, Karnataka, and Kerala. Transparent pricing, goods-in-transit insurance, 24/7 support. Call +91 77310 74075."
  schema={faqSchema}
>
  <!-- ── HERO ── -->
  <section class="bg-hero bg-grid min-h-screen flex items-center relative overflow-hidden">
    <!-- Decorative orbs -->
    <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-brand-500/12 rounded-full blur-3xl animate-pulse pointer-events-none" style="animation-duration:4s"></div>
    <div class="absolute bottom-1/4 left-1/4 w-80 h-80 bg-orange-400/15 rounded-full blur-3xl pointer-events-none" style="animation: float 7s ease-in-out infinite"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-olive-400/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 w-full relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left Content -->
        <div class="text-center lg:text-left">
          <!-- Live indicator -->
          <div class="inline-flex items-center gap-2.5 bg-white/80 border border-slate-200 rounded-full px-4 py-2 mb-8 backdrop-blur-sm shadow-sm">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
            </span>
            <span class="text-slate-700 text-sm font-semibold tracking-wide">Available Now · 100 Cities · 5 States</span>
          </div>

          <h1 class="display-xl font-display font-black text-slate-900 mb-6 leading-[1.05]">
            South India's
            <span class="gold-text block">Most Trusted</span>
            <span class="text-brand-700">Movers</span>
          </h1>

          <p class="text-slate-600 text-lg leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
            Professional packers and movers across Andhra Pradesh, Telangana, Tamil Nadu, Karnataka, and Kerala. All-inclusive pricing, goods-in-transit insurance, and a 100% Safe Delivery Guarantee on every move.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-10">
            <a href="tel:+917731074075" class="btn-gold text-base py-4 px-8 shadow-[0_8px_30px_rgba(245,158,11,0.5)]">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              Call: +91 77310 74075
            </a>
            <a href="https://wa.me/917731074075" target="_blank" rel="noopener" class="btn-ghost text-base py-4 px-8">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Quote
            </a>
          </div>

          <!-- Trust badges -->
          <div class="flex flex-wrap gap-2.5 justify-center lg:justify-start">
            {['✅ 100% Safe Guarantee','🔒 Transit Insurance','⚡ No Hidden Charges','📍 100 Cities'].map(b => (
              <span class="trust-badge text-xs">{b}</span>
            ))}
          </div>
        </div>

        <!-- Right: Booking Engine -->
        <div class="w-full">
          <BookingEngine />
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-16 pt-12 border-t border-slate-200">
        {stats.map((s, i) => (
          <div class="stat-card reveal" style={`transition-delay:${i*0.1}s`}>
            <div class="stat-number">{s.num}</div>
            <div class="text-slate-600 text-sm font-medium mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2 text-slate-400" aria-hidden="true">
      <span class="text-xs font-medium tracking-widest uppercase">Scroll</span>
      <div class="w-0.5 h-12 bg-gradient-to-b from-slate-300 to-transparent" style="animation: bounce 1.5s ease-in-out infinite"></div>
    </div>
  </section>

  <!-- ── STATES GRID ── -->
  <section class="py-20 bg-white" aria-labelledby="states-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="section-badge mb-4">5 States · 100 Cities</span>
        <h2 id="states-heading" class="section-title mb-4">We Move South India</h2>
        <p class="section-subtitle mx-auto">From coastal Andhra to Kerala's backwaters — one trusted partner for every South Indian relocation.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-5">
        {statesData.map((state, i) => (
          <a href={state.url} class="glass-card p-6 text-center group reveal" style={`transition-delay:${i*0.08}s`}>
            <div class="text-3xl mb-3 group-hover:scale-110 transition-transform">{stateEmojis[i]}</div>
            <div class="font-bold text-slate-900 font-display group-hover:text-brand-600 transition-colors">{state.name}</div>
            <div class="text-brand-600 text-sm font-semibold mt-1">{state.cityCount} cities</div>
            <div class="text-slate-500 text-xs mt-2 leading-snug">{state.tagline}</div>
            <div class="mt-4 text-brand-600 text-xs font-bold opacity-0 group-hover:opacity-100 transition-opacity">Explore cities →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SERVICES ── -->
  <section class="py-20 bg-slate-50" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="section-badge section-badge-olive mb-4">What We Do</span>
        <h2 id="services-heading" class="section-title mb-4">Complete Relocation Services</h2>
        <p class="section-subtitle mx-auto">Every service you need for a smooth, stress-free move — handled by trained professionals.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s, i) => (
          <div class="service-card reveal" style={`transition-delay:${i*0.07}s`}>
            <div class="text-4xl mb-4">{s.icon}</div>
            <h3 class="font-bold text-lg text-slate-900 font-display mb-2">{s.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{s.desc}</p>
            <a href={s.link} class="mt-4 text-brand-600 text-sm font-semibold hover:underline inline-flex items-center gap-1 group">
              Learn more
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── WHY PACKERSHUB ── -->
  <section class="py-20 bg-white" aria-labelledby="why-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <span class="section-badge mb-6">Why Choose Us</span>
          <h2 id="why-heading" class="section-title mb-6">Not Just a Truck and a Phone Number</h2>
          <p class="text-slate-600 leading-relaxed mb-8">PackersHub brings genuine local knowledge to every one of our 100 cities — from coastal humidity considerations in Visakhapatnam to hill-route logistics in Ooty, from festival traffic planning in Tirupati to monsoon scheduling across Kerala.</p>
          <div class="space-y-5">
            {[
              ['🎯','Transparent Pricing','One all-inclusive quote — no hidden charges for stairs, fuel, or packing materials. You pay exactly what was agreed.'],
              ['🛡️','Transit Insurance Included','Every consignment carries goods-in-transit insurance as standard, not as an upsell.'],
              ['📍','100 Cities. Real Local Teams.','Not call-centre subcontracting. Our local crews know your neighbourhood.'],
              ['💳','Flexible Payment','UPI, NEFT, Credit/Debit Card, Cash — no cash-only pressure.'],
            ].map(([icon, title, desc]) => (
              <div class="flex gap-4 group">
                <span class="text-2xl flex-shrink-0 group-hover:scale-110 transition-transform">{icon}</span>
                <div>
                  <div class="font-bold text-slate-900 mb-1 font-display">{title}</div>
                  <div class="text-slate-600 text-sm leading-relaxed">{desc}</div>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-8 flex gap-4">
            <a href="tel:+917731074075" class="btn-primary">Call: +91 77310 74075</a>
            <a href="/about/" class="btn-secondary">About Us</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4 reveal">
          {[['100+','Cities Served'],['5','States Covered'],['₹0','Hidden Charges'],['24/7','Customer Support']].map(([num, label], i) => (
            <div class="bg-gradient-to-br from-brand-50 to-brand-100 rounded-2xl p-6 text-center border border-brand-100 hover:border-brand-300 transition-colors hover:shadow-lg">
              <div class="text-3xl font-black text-brand-700 font-display">{num}</div>
              <div class="text-slate-700 text-sm font-medium mt-2">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ── -->
  <section class="py-20 bg-slate-50" aria-labelledby="testimonials-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="section-badge section-badge-orange mb-4">Customer Stories</span>
        <h2 id="testimonials-heading" class="section-title mb-4">What Customers Say</h2>
        <p class="section-subtitle mx-auto">Real experiences from real moves across South India.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-lg transition-shadow reveal" style={`transition-delay:${i*0.1}s`}>
            <div class="flex items-center gap-1 mb-4">
              {Array.from({length: t.stars}).map(() => (
                <span class="text-yellow-400 text-base" aria-hidden="true">★</span>
              ))}
            </div>
            <blockquote class="text-slate-700 text-sm leading-relaxed mb-4 italic">"{t.text}"</blockquote>
            <div class="flex items-center justify-between">
              <div>
                <div class="font-bold text-slate-900 text-sm">{t.name}</div>
                <div class="text-brand-600 text-xs font-medium">{t.city}</div>
              </div>
              <span class="text-slate-400 text-xs">{t.date}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TOP CITIES ── -->
  <section class="py-20 bg-white" aria-labelledby="cities-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="section-badge mb-4">Popular Destinations</span>
        <h2 id="cities-heading" class="section-title mb-4">Top Cities We Serve</h2>
        <p class="section-subtitle mx-auto">Quick links to our most-booked relocation destinations across South India.</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        {topCities.map((city, i) => (
          <a href={city.url} class="city-card reveal" style={`transition-delay:${i*0.06}s`}>
            <div class="font-bold text-slate-900 text-sm font-display">{city.name}</div>
            <div class="text-brand-600 text-xs font-medium mt-0.5">{city.stateName.split(' ')[0]}</div>
            <div class="text-slate-400 text-xs mt-1 line-clamp-2">{city.tagline}</div>
          </a>
        ))}
      </div>
      <div class="text-center mt-10">
        <p class="text-slate-600 text-sm mb-4">We serve 100 cities across South India. Find your city:</p>
        <div class="flex flex-wrap justify-center gap-3">
          {statesData.map(s => (
            <a href={s.url} class="route-tag">{s.name} ({s.cityCount})</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── GUARANTEE ── -->
  <section class="py-20 bg-hero relative overflow-hidden" aria-labelledby="guarantee-heading">
    <div class="absolute inset-0 bg-grid opacity-40 pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 reveal">
      <div class="text-6xl mb-6" aria-hidden="true">🛡️</div>
      <h2 id="guarantee-heading" class="display-lg text-slate-900 font-display font-black mb-6">100% Safe Delivery Guarantee</h2>
      <p class="text-slate-600 text-lg leading-relaxed mb-8 max-w-2xl mx-auto">
        Your belongings arrive in the same condition they left in, on the agreed date, with nothing missing or damaged. Every item is photographed and logged at pickup. Every vehicle is GPS-tracked. Every consignment is insured. If anything goes wrong, our claims process ensures fair, prompt compensation.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="tel:+917731074075" class="btn-gold py-4 px-8 text-base">📞 Call: +91 77310 74075</a>
        <a href="https://wa.me/917731074075" target="_blank" rel="noopener" class="btn-ghost py-4 px-8 text-base">💬 WhatsApp Quote</a>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="py-20 bg-white" aria-labelledby="faq-heading">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="section-badge mb-4">FAQ</span>
        <h2 id="faq-heading" class="section-title mb-4">Common Questions</h2>
        <p class="section-subtitle mx-auto">Everything you need to know before booking your move.</p>
      </div>
      <div class="space-y-3" itemscope itemtype="https://schema.org/FAQPage">
        {faqs.map((f, i) => (
          <div class="faq-item reveal" style={`transition-delay:${i*0.05}s`} data-faq itemscope itemtype="https://schema.org/Question">
            <div class="faq-question" data-faq-q aria-expanded="false">
              <span itemprop="name">{f.q}</span>
              <span class="faq-icon" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                </svg>
              </span>
            </div>
            <div class="faq-answer" data-faq-a>
              <div class="faq-answer-inner" itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                <span itemprop="text">{f.a}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── BOTTOM CTA ── -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-4xl mx-auto px-4 text-center reveal">
      <h2 class="section-title mb-4">Ready to Move? Let's Make It Easy.</h2>
      <p class="section-subtitle mx-auto mb-8">Get your free, all-inclusive quote in under 30 minutes. No obligation, no pressure.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+917731074075" class="btn-primary text-base py-4 px-8">📞 Call: +91 77310 74075</a>
        <a href="https://wa.me/917731074075" target="_blank" rel="noopener" class="btn-gold text-base py-4 px-8">💬 WhatsApp Us Now</a>
      </div>
      <p class="text-slate-500 text-sm mt-4">PackersHub · BV Nagar, Nellore, Andhra Pradesh 524004</p>
    </div>
  </section>
</BaseLayout>

<script>
// FAQ accordion with keyboard support
document.querySelectorAll('[data-faq]').forEach(item => {
  const q = item.querySelector('[data-faq-q]');
  const a = item.querySelector('[data-faq-a]');

  q?.setAttribute('role', 'button');
  q?.setAttribute('tabindex', '0');

  const toggle = () => {
    const isOpen = a?.classList.contains('open');
    document.querySelectorAll('[data-faq-a]').forEach(el => el.classList.remove('open'));
    document.querySelectorAll('[data-faq]').forEach(el => el.classList.remove('open'));
    document.querySelectorAll('[data-faq-q]').forEach(el => el.setAttribute('aria-expanded', 'false'));
    if (!isOpen) {
      a?.classList.add('open');
      item.classList.add('open');
      q?.setAttribute('aria-expanded', 'true');
    }
  };

  q?.addEventListener('click', toggle);
  q?.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); } });
});
</script>
