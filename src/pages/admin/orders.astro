---
// v9.1 — new file. Staff-only tool, excluded from search via noindex AND
// Disallow: /admin/ in robots.txt. Not linked from any public nav menu.
//
// v10.6.2 — Payment + GPS visibility added (closes the gap flagged in the
// v10.6.1 bug audit: staff previously had no way to see payment/GPS status
// without opening /track/ separately, or push a GPS point without curl).
// No new API routes needed — /api/admin/order already returns the full KV
// record, which already contains paymentStatus / gpsLatest / gpsHistory
// (written by /api/payment/verify and /api/gps/update respectively).
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Staff — Update Order Status"
  description="Internal tool for PackersHub staff to update booking status."
  noindex={true}
>
  <section class="py-16 bg-gray-50 min-h-screen">
    <div class="max-w-xl mx-auto px-4">
      <h1 class="text-2xl font-display font-extrabold text-brand-dark mb-2">Update Booking Status</h1>
      <p class="text-brand-grey mb-8 text-sm">Internal tool. Enter your staff token once — it's remembered on this device.</p>

      <div class="bg-white rounded-2xl shadow-card border border-gray-100 p-6 mb-6">
        <label class="block text-sm font-semibold text-brand-dark mb-1.5">Staff Token</label>
        <div class="flex gap-2">
          <input type="password" id="admin-token" class="flex-1 px-4 py-2.5 rounded-xl border border-gray-200 outline-none focus:border-brand-orange" placeholder="Paste staff token" />
          <button id="save-token" class="px-4 py-2.5 rounded-xl border border-gray-200 font-semibold hover:border-brand-orange hover:text-brand-orange transition-colors" type="button">Save</button>
        </div>
        <p class="text-xs text-brand-grey mt-1.5" id="token-status"></p>
      </div>

      <div class="bg-white rounded-2xl shadow-card border border-gray-100 p-6 mb-6">
        <label class="block text-sm font-semibold text-brand-dark mb-1.5">Tracking ID</label>
        <div class="flex gap-2">
          <input type="text" id="lookup-id" class="flex-1 px-4 py-2.5 rounded-xl border border-gray-200 outline-none focus:border-brand-orange" placeholder="e.g. PH-7K2M9X" />
          <button id="lookup-btn" class="px-4 py-2.5 rounded-xl border border-gray-200 font-semibold hover:border-brand-orange hover:text-brand-orange transition-colors" type="button">Look Up</button>
        </div>
        <p class="text-red-600 text-sm font-medium mt-2" id="lookup-error" style="display:none"></p>
      </div>

      <div class="bg-white rounded-2xl shadow-card border border-gray-100 p-6 mb-6" id="record-card" style="display:none">
        <h2 class="font-bold text-lg text-brand-dark mb-4" id="record-name"></h2>

        <!-- Payment status chip -->
        <div id="payment-chip" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold mb-2" style="display:none"></div>

        <div class="text-sm text-brand-grey space-y-1 mb-6" id="record-details"></div>

        <label class="block text-sm font-semibold text-brand-dark mb-1.5">New Status</label>
        <select id="status-select" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 outline-none focus:border-brand-orange mb-3"></select>

        <label class="block text-sm font-semibold text-brand-dark mb-1.5">Note (optional)</label>
        <textarea id="status-note" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 outline-none focus:border-brand-orange mb-4" placeholder="e.g. Crew dispatched, ETA 4 PM"></textarea>

        <button id="update-btn" class="w-full py-3 rounded-full bg-gradient-to-r from-brand-orange to-brand-gold text-white font-bold" type="button">Update Status</button>
        <p class="text-xs text-brand-grey mt-3" id="update-result"></p>
      </div>

      <!-- GPS card — last known position + push-update form. Only shown once a record is looked up. -->
      <div class="bg-white rounded-2xl shadow-card border border-gray-100 p-6 mt-6" id="gps-card" style="display:none">
        <h2 class="font-bold text-lg text-brand-dark mb-1">GPS Tracking</h2>
        <p class="text-sm text-brand-grey mb-4" id="gps-last-seen">No GPS data pushed yet for this booking.</p>

        <div class="border-t border-gray-100 pt-4">
          <p class="text-xs font-semibold text-brand-dark mb-2.5 uppercase tracking-wide">Push New GPS Point</p>

          <div class="grid grid-cols-2 gap-2 mb-2">
            <input type="text" id="gps-lat" inputmode="decimal" class="px-3 py-2 rounded-xl border border-gray-200 outline-none focus:border-brand-orange text-sm" placeholder="Latitude e.g. 15.8281" />
            <input type="text" id="gps-lng" inputmode="decimal" class="px-3 py-2 rounded-xl border border-gray-200 outline-none focus:border-brand-orange text-sm" placeholder="Longitude e.g. 78.0373" />
          </div>
          <input type="text" id="gps-note" class="w-full px-3 py-2 rounded-xl border border-gray-200 outline-none focus:border-brand-orange text-sm mb-2" placeholder="Note — e.g. Near Kurnool toll" />
          <div class="grid grid-cols-2 gap-2 mb-2">
            <input type="text" id="gps-eta" class="px-3 py-2 rounded-xl border border-gray-200 outline-none focus:border-brand-orange text-sm" placeholder="ETA — e.g. Tomorrow 2 PM" />
            <input type="text" id="gps-vehicle" class="px-3 py-2 rounded-xl border border-gray-200 outline-none focus:border-brand-orange text-sm" placeholder="Vehicle No." />
          </div>

          <details class="mb-3">
            <summary class="text-xs text-brand-grey cursor-pointer select-none">GPS push token (different from staff token above — set once)</summary>
            <input type="password" id="gps-token" class="w-full px-3 py-2 mt-2 rounded-xl border border-gray-200 outline-none focus:border-brand-orange text-sm" placeholder="GPS_ADMIN_TOKEN" />
          </details>

          <button id="gps-push-btn" class="w-full py-3 rounded-full bg-gradient-to-r from-brand-orange to-brand-gold text-white font-bold" type="button">Push GPS Update</button>
          <p class="text-xs text-brand-grey mt-3" id="gps-push-result"></p>
        </div>

        <!-- Driver self-report link — generated client-side from the GPS token
             above, so the master GPS_ADMIN_TOKEN never has to be shared with
             the driver. Send this link to the driver over WhatsApp; they tap
             one button to share their live location, no app/login needed. -->
        <div class="border-t border-gray-100 pt-4 mt-4">
          <p class="text-xs font-semibold text-brand-dark mb-2.5 uppercase tracking-wide">Driver Self-Report Link</p>
          <p class="text-xs text-brand-grey mb-2.5">Send this to the driver on WhatsApp — they tap one button to share GPS themselves. No app, no GPS token shared with them.</p>
          <button id="driver-link-btn" class="w-full py-2.5 rounded-full border-2 border-brand-orange text-brand-orange font-bold text-sm" type="button">Generate Driver Link</button>
          <div id="driver-link-result" class="mt-2.5" style="display:none">
            <input type="text" id="driver-link-output" readonly class="w-full px-3 py-2 rounded-xl border border-gray-200 outline-none text-xs bg-gray-50" />
            <div class="flex gap-2 mt-2">
              <button id="driver-link-copy" type="button" class="flex-1 py-2 rounded-full border border-gray-200 text-xs font-semibold">📋 Copy</button>
              <a id="driver-link-whatsapp" href="#" target="_blank" rel="noopener" class="flex-1 py-2 rounded-full bg-green-500 text-white text-xs font-semibold text-center">💬 Send via WhatsApp</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
const tokenInput = document.getElementById('admin-token');
const tokenStatus = document.getElementById('token-status');
const STORAGE_KEY = 'ph_admin_token';
const GPS_STORAGE_KEY = 'ph_gps_admin_token';

function getToken() { return localStorage.getItem(STORAGE_KEY) || ''; }
function getGpsToken() { return localStorage.getItem(GPS_STORAGE_KEY) || ''; }

(function initToken() {
  const saved = getToken();
  if (saved) {
    tokenInput.value = saved;
    tokenStatus.textContent = 'Token loaded from this device.';
  }
  const savedGps = getGpsToken();
  if (savedGps) {
    const gpsTokenInput = document.getElementById('gps-token');
    if (gpsTokenInput) gpsTokenInput.value = savedGps;
  }
})();

document.getElementById('save-token').addEventListener('click', () => {
  localStorage.setItem(STORAGE_KEY, tokenInput.value.trim());
  tokenStatus.textContent = 'Saved on this device.';
});

// Save the GPS token to this device as soon as the staff member types one —
// same low-friction pattern as the staff token above, just a separate key
// since GPS_ADMIN_TOKEN and ADMIN_TOKEN are different Cloudflare secrets.
document.getElementById('gps-token').addEventListener('change', (e) => {
  localStorage.setItem(GPS_STORAGE_KEY, e.target.value.trim());
});

let currentId = null;

// Small relative-time helper — "12 min ago", "3 hr ago", "2 days ago".
// No library needed for this single use.
function timeAgo(iso) {
  if (!iso) return '';
  const diffMs = Date.now() - new Date(iso).getTime();
  const mins = Math.round(diffMs / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins} min ago`;
  const hrs = Math.round(mins / 60);
  if (hrs < 24) return `${hrs} hr ago`;
  const days = Math.round(hrs / 24);
  return `${days} day${days === 1 ? '' : 's'} ago`;
}

function renderPaymentChip(record) {
  const chip = document.getElementById('payment-chip');
  if (record.paymentStatus === 'paid') {
    chip.style.display = 'inline-flex';
    chip.className = 'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold mb-2 bg-green-50 text-green-700 border border-green-200';
    const label = record.paymentType === 'full' ? '✅ Fully Paid' : '✅ Advance Paid';
    chip.textContent = `${label}${record.paidAt ? ' · ' + timeAgo(record.paidAt) : ''}`;
  } else {
    chip.style.display = 'inline-flex';
    chip.className = 'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold mb-2 bg-gray-100 text-brand-grey border border-gray-200';
    chip.textContent = '⏳ Not Paid';
  }
}

function renderGpsCard(record) {
  const lastSeen = document.getElementById('gps-last-seen');
  const g = record.gpsLatest;
  if (g && g.at) {
    const parts = [
      `📍 ${g.lat.toFixed(4)}, ${g.lng.toFixed(4)}`,
      `· ${timeAgo(g.at)}`,
    ];
    lastSeen.innerHTML = [
      `<strong>Last position:</strong> ${parts.join(' ')}`,
      g.note ? `<div>Note: ${g.note}</div>` : '',
      g.eta ? `<div>ETA: ${g.eta}</div>` : '',
      g.vehicleNo ? `<div>Vehicle: ${g.vehicleNo}</div>` : '',
      g.speed ? `<div>Speed: ${g.speed} km/h</div>` : '',
      Array.isArray(record.gpsHistory) ? `<div class="text-xs mt-1">${record.gpsHistory.length} point(s) in breadcrumb trail.</div>` : '',
    ].filter(Boolean).join('');
  } else {
    lastSeen.textContent = 'No GPS data pushed yet for this booking.';
  }
  // Pre-fill the push form's lat/lng with the last known point so staff can
  // nudge it slightly rather than typing full coordinates every time.
  if (g) {
    document.getElementById('gps-lat').value = g.lat;
    document.getElementById('gps-lng').value = g.lng;
    if (g.vehicleNo) document.getElementById('gps-vehicle').value = g.vehicleNo;
  }
}

document.getElementById('lookup-btn').addEventListener('click', async () => {
  const id = document.getElementById('lookup-id').value.trim().toUpperCase();
  const errorEl = document.getElementById('lookup-error');
  const card = document.getElementById('record-card');
  const gpsCard = document.getElementById('gps-card');
  errorEl.style.display = 'none';
  card.style.display = 'none';
  gpsCard.style.display = 'none';

  if (!id) { errorEl.textContent = 'Enter a Tracking ID.'; errorEl.style.display = 'block'; return; }

  try {
    const res = await fetch(`/api/admin/order?id=${encodeURIComponent(id)}`, {
      headers: { 'x-admin-token': getToken() },
    });
    const data = await res.json();
    if (!data.ok) {
      errorEl.textContent = data.error || 'Lookup failed.';
      errorEl.style.display = 'block';
      return;
    }

    currentId = data.record.trackingId;
    document.getElementById('record-name').textContent =
      `${data.record.name || 'Unknown'} — ${data.record.trackingId}`;
    document.getElementById('record-details').innerHTML = [
      `Phone: ${data.record.phone}`,
      data.record.email ? `Email: ${data.record.email}` : '',
      (data.record.fromCity || data.record.toCity) ? `Route: ${data.record.fromCity || '-'} → ${data.record.toCity || '-'}` : '',
      data.record.moveDate ? `Move date: ${data.record.moveDate}` : '',
      data.record.message ? `Message: ${data.record.message}` : '',
      `Current status: <strong>${data.record.status}</strong>`,
    ].filter(Boolean).map(l => `<div>${l}</div>`).join('');

    renderPaymentChip(data.record);
    renderGpsCard(data.record);

    const select = document.getElementById('status-select');
    select.innerHTML = data.stages.map(s =>
      `<option value="${s}" ${s === data.record.status ? 'selected' : ''}>${s}</option>`
    ).join('');

    card.style.display = 'block';
    gpsCard.style.display = 'block';
  } catch {
    errorEl.textContent = 'Network error. Please try again.';
    errorEl.style.display = 'block';
  }
});

document.getElementById('update-btn').addEventListener('click', async () => {
  if (!currentId) return;
  const status = document.getElementById('status-select').value;
  const note = document.getElementById('status-note').value.trim();
  const resultEl = document.getElementById('update-result');

  try {
    const res = await fetch('/api/admin/order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-admin-token': getToken() },
      body: JSON.stringify({ id: currentId, status, note }),
    });
    const data = await res.json();
    resultEl.textContent = data.ok ? `Updated to "${status}".` : (data.error || 'Update failed.');
    // Status may now affect payment/GPS context (e.g. just reached "In Transit") —
    // refresh the chip + GPS card from the server's confirmed record rather than
    // assuming nothing else changed.
    if (data.ok && data.record) {
      renderPaymentChip(data.record);
      renderGpsCard(data.record);
    }
  } catch {
    resultEl.textContent = 'Network error. Please try again.';
  }
});

document.getElementById('gps-push-btn').addEventListener('click', async () => {
  const resultEl = document.getElementById('gps-push-result');
  if (!currentId) { resultEl.textContent = 'Look up a booking first.'; return; }

  const lat = parseFloat(document.getElementById('gps-lat').value);
  const lng = parseFloat(document.getElementById('gps-lng').value);
  const note = document.getElementById('gps-note').value.trim();
  const eta = document.getElementById('gps-eta').value.trim();
  const vehicleNo = document.getElementById('gps-vehicle').value.trim();
  const gpsToken = document.getElementById('gps-token').value.trim();

  if (Number.isNaN(lat) || Number.isNaN(lng)) {
    resultEl.textContent = 'Enter valid latitude and longitude.';
    return;
  }
  if (!gpsToken) {
    resultEl.textContent = 'Enter the GPS push token (see the field above the button).';
    return;
  }

  resultEl.textContent = 'Pushing…';
  try {
    const res = await fetch('/api/gps/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${gpsToken}` },
      body: JSON.stringify({
        trackingId: currentId,
        lat, lng,
        ...(note ? { note } : {}),
        ...(eta ? { eta } : {}),
        ...(vehicleNo ? { vehicleNo } : {}),
      }),
    });
    const data = await res.json();
    if (data.ok) {
      localStorage.setItem(GPS_STORAGE_KEY, gpsToken);
      resultEl.textContent = `GPS updated — ${data.pointsKept} point(s) now in trail.`;
      document.getElementById('gps-last-seen').innerHTML =
        `<strong>Last position:</strong> 📍 ${lat.toFixed(4)}, ${lng.toFixed(4)} · just now` +
        (note ? `<div>Note: ${note}</div>` : '') +
        (eta ? `<div>ETA: ${eta}</div>` : '') +
        (vehicleNo ? `<div>Vehicle: ${vehicleNo}</div>` : '');
    } else {
      resultEl.textContent = data.error || 'GPS push failed.';
    }
  } catch {
    resultEl.textContent = 'Network error. Please try again.';
  }
});

// ── Driver self-report link generator ──────────────────────────────────────
// Computes the scoped per-booking token client-side using Web Crypto, so the
// master GPS_ADMIN_TOKEN never has to be typed or sent anywhere except this
// HMAC step — the driver only ever receives the derived token in the link.
// Must match the server-side computeDriverToken() in
// src/pages/api/gps/driver-update.ts byte-for-byte.
async function computeDriverToken(secret, trackingId) {
  const enc = new TextEncoder();
  const key = await crypto.subtle.importKey(
    'raw', enc.encode(secret),
    { name: 'HMAC', hash: 'SHA-256' },
    false, ['sign'],
  );
  const sigBuf = await crypto.subtle.sign('HMAC', key, enc.encode(trackingId));
  return [...new Uint8Array(sigBuf)].map(b => b.toString(16).padStart(2, '0')).join('');
}

document.getElementById('driver-link-btn').addEventListener('click', async () => {
  const resultBox = document.getElementById('driver-link-result');
  const output    = document.getElementById('driver-link-output');
  const copyBtn   = document.getElementById('driver-link-copy');
  const waLink    = document.getElementById('driver-link-whatsapp');

  if (!currentId) { alert('Look up a booking first.'); return; }
  const gpsToken = document.getElementById('gps-token').value.trim();
  if (!gpsToken) { alert('Enter the GPS push token first — the driver link is derived from it.'); return; }

  const driverToken = await computeDriverToken(gpsToken, currentId);
  const link = `${window.location.origin}/driver/${currentId}?t=${driverToken}`;

  output.value = link;
  resultBox.style.display = 'block';

  const message = `Hi! Please open this link and tap "Share Current Location" so we can track your trip for booking ${currentId}: ${link}`;
  waLink.href = `https://wa.me/?text=${encodeURIComponent(message)}`;

  copyBtn.onclick = () => {
    navigator.clipboard.writeText(link).then(() => {
      copyBtn.textContent = '✅ Copied';
      setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 1500);
    });
  };
});
</script>
