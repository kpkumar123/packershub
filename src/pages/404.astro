---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found — PackersHub" description="This page could not be found." noindex={true}>
  <section class="bg-hero bg-grid min-h-screen flex items-center">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="text-8xl font-black text-slate-900/15 font-display mb-4">404</div>
      <h1 class="text-slate-900 font-bold text-3xl font-display mb-4">Page Not Found</h1>
      <p class="text-slate-600 mb-8">The page you are looking for does not exist. Try our homepage or contact us directly.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-gold">← Back to Home</a>
        <a href="tel:+917731074075" class="btn-ghost">📞 Call Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
