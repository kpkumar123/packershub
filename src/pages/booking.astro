---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingEngine from '../components/BookingEngine.astro';
---
<BaseLayout
  title="Book Packers & Movers Online | Instant Price Estimate — PackersHub"
  description="Book packers and movers online with instant price comparison across 100 South Indian cities. Get transparent estimates, compare with market rates, and book via WhatsApp in minutes."
>
  <!-- Hero Banner -->
  <section class="bg-hero min-h-[280px] flex items-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center w-full">
      <div class="inline-flex items-center gap-2 bg-blue-50 border border-blue-200 rounded-full px-4 py-2 mb-6">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        <span class="text-slate-700 text-sm font-semibold">Instant Price Comparison Engine</span>
      </div>
      <h1 class="display-lg font-display font-black text-slate-900 mb-4 leading-tight">
        Book Your Move Online
        <span class="gold-text block">Get Instant Price Estimate</span>
      </h1>
      <p class="text-slate-600 text-lg max-w-2xl mx-auto">
        Compare PackersHub pricing vs market average across 100 cities. Transparent breakdown — no hidden charges.
      </p>
    </div>
  </section>

  <!-- Booking Engine -->
  <section class="bg-slate-50 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <BookingEngine />
    </div>
  </section>

  <!-- Why Booking Online -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 reveal">
        <h2 class="section-title mb-3">Why Book Online with PackersHub?</h2>
        <p class="section-subtitle mx-auto">Smarter than calling around for quotes</p>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        {[
          { icon: '⚡', title: 'Instant Estimate', desc: 'Get a detailed, itemised price estimate in under 60 seconds — before you even speak to anyone.' },
          { icon: '📊', title: 'Market Comparison', desc: 'See how our all-inclusive price compares to what other movers typically charge — with full transparency.' },
          { icon: '💬', title: 'WhatsApp Confirmation', desc: 'Your booking summary goes directly to WhatsApp — our team confirms within 30 minutes.' },
        ].map(f => (
          <div class="service-card reveal text-center">
            <div class="text-4xl mb-3">{f.icon}</div>
            <h3 class="font-bold text-lg font-display mb-2">{f.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
