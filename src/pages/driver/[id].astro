---
// src/pages/driver/[id].astro — PackersHub v10.6.3
//
// A no-login, no-app page a driver opens from a WhatsApp link to share
// their live location for one specific booking. Rendered on-demand
// (prerender = false) since the tracking ID is dynamic and not known at
// build time — same hybrid-rendering pattern already used by /track/'s
// API routes elsewhere in this project.
//
// Security model: the `t` query param is a per-booking HMAC token (see
// src/pages/api/gps/driver-update.ts for how it's derived and verified).
// This page itself shows no booking details — just a location-share
// button — so even the booking's tracking ID alone leaking is low-risk.
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;

const trackingId = (Astro.params.id || '').toUpperCase();
const isValidId = /^PH-[A-Z2-9]{6}$/.test(trackingId);
---
<BaseLayout
  title="Share Trip Location — PackersHub"
  description="Driver location-sharing page for an active PackersHub move."
  noindex={true}
>
  <section class="py-16 bg-gray-50 min-h-screen">
    <div class="max-w-md mx-auto px-4">
      {!isValidId ? (
        <div class="bg-white rounded-2xl shadow-card border border-gray-100 p-6 text-center">
          <p class="text-red-600 font-semibold">Invalid link.</p>
          <p class="text-sm text-brand-grey mt-2">Please check the link sent to you, or contact PackersHub.</p>
        </div>
      ) : (
        <div class="bg-white rounded-2xl shadow-card border border-gray-100 p-6 text-center" id="driver-card">
          <div class="text-4xl mb-3">🚛</div>
          <h1 class="font-bold text-xl text-brand-dark mb-1">Share Trip Location</h1>
          <p class="text-sm text-brand-grey mb-1">Booking: <strong>{trackingId}</strong></p>
          <p class="text-sm text-brand-grey mb-6">Tap the button below each time you stop, or leave this page open — your location updates customers' tracking page automatically.</p>

          <button id="share-once-btn" type="button" class="w-full py-3.5 rounded-full bg-gradient-to-r from-brand-orange to-brand-gold text-white font-bold mb-3">
            📍 Share Current Location
          </button>

          <button id="share-live-btn" type="button" class="w-full py-3 rounded-full border-2 border-brand-orange text-brand-orange font-bold">
            🔴 Start Live Sharing (every 2 min)
          </button>

          <p class="text-xs text-brand-grey mt-4" id="driver-status"></p>

          <div class="mt-5 pt-5 border-t border-gray-100 text-left">
            <label class="block text-xs font-semibold text-brand-dark mb-1">Note (optional — e.g. "Near Kurnool toll")</label>
            <input type="text" id="driver-note" class="w-full px-3 py-2 rounded-xl border border-gray-200 outline-none focus:border-brand-orange text-sm mb-2" placeholder="Quick note for the customer" />
            <label class="block text-xs font-semibold text-brand-dark mb-1">Vehicle Number (optional)</label>
            <input type="text" id="driver-vehicle" class="w-full px-3 py-2 rounded-xl border border-gray-200 outline-none focus:border-brand-orange text-sm" placeholder="e.g. AP 15 AB 1234" />
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

{isValidId && (
  <script define:vars={{ trackingId }}>
    const params      = new URLSearchParams(window.location.search);
    const driverToken = params.get('t') || '';
    const statusEl    = document.getElementById('driver-status');
    const onceBtn     = document.getElementById('share-once-btn');
    const liveBtn     = document.getElementById('share-live-btn');
    const noteInput   = document.getElementById('driver-note');
    const vehicleInput = document.getElementById('driver-vehicle');

    let liveInterval = null;

    function setStatus(msg, isError) {
      statusEl.textContent = msg;
      statusEl.style.color = isError ? '#b91c1c' : '#16a34a';
    }

    async function pushPosition(coords) {
      const body = {
        trackingId,
        driverToken,
        lat: coords.latitude,
        lng: coords.longitude,
        note: noteInput.value.trim() || undefined,
        vehicleNo: vehicleInput.value.trim() || undefined,
      };
      try {
        const res = await fetch('/api/gps/driver-update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (data.ok) {
          setStatus(`✅ Location shared at ${new Date().toLocaleTimeString('en-IN')}`, false);
        } else {
          setStatus(`⚠️ ${data.error || 'Could not share location.'}`, true);
        }
      } catch {
        setStatus('Network error — please try again.', true);
      }
    }

    function getPositionOnce() {
      if (!('geolocation' in navigator)) {
        setStatus('Location is not supported on this device/browser.', true);
        return;
      }
      setStatus('Getting location…', false);
      navigator.geolocation.getCurrentPosition(
        (pos) => pushPosition(pos.coords),
        () => setStatus('Location permission denied. Please allow location access and try again.', true),
        { enableHighAccuracy: true, timeout: 15000 },
      );
    }

    onceBtn.addEventListener('click', getPositionOnce);

    liveBtn.addEventListener('click', () => {
      if (liveInterval) {
        clearInterval(liveInterval);
        liveInterval = null;
        liveBtn.textContent = '🔴 Start Live Sharing (every 2 min)';
        setStatus('Live sharing stopped.', false);
        return;
      }
      getPositionOnce();
      liveInterval = setInterval(getPositionOnce, 2 * 60 * 1000);
      liveBtn.textContent = '⏹ Stop Live Sharing';
      setStatus('Live sharing started — keep this tab open.', false);
    });
  </script>
)}
