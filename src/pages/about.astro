---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustStrip from '../components/TrustStrip.astro';
import QuoteForm from '../components/QuoteForm.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About PackersHub — South India's #1 Packers & Movers",
  "url": "https://www.packershub.in/about",
  "mainEntity": { "@id": "https://www.packershub.in/#organization" }
};
---
<BaseLayout
  title="About PackersHub — South India's Packers & Movers Since 2018"
  description="PackersHub is a packers and movers company founded in 2018 in Nellore, AP, serving 100+ cities across 5 South Indian states. Know our story, team & values."
  keywords="about packershub, packershub history, packers movers nellore, south india relocation company, best movers ap telangana"
  canonical="https://www.packershub.in/about"
  schema={schema}
>
  <!-- Hero -->
  <section class="hero-bg pt-16 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex justify-center items-center gap-2 text-sm text-brand-grey" role="list">
          <li><a href="/" class="hover:text-brand-orange">Home</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-brand-orange font-semibold" aria-current="page">About Us</li>
        </ol>
      </nav>
      <span class="inline-block px-4 py-1.5 rounded-full bg-orange-100 text-brand-orange text-sm font-bold mb-5 uppercase tracking-wide">Our Story</span>
      <h1 class="font-display font-extrabold text-5xl lg:text-6xl text-brand-dark mb-6">
        About <span class="text-gradient">PackersHub</span>
      </h1>
      <p class="text-xl text-brand-grey max-w-2xl mx-auto leading-relaxed">
        Since 2018, we've been making relocations easier, safer, and stress-free for families and businesses across South India.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- Story -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="font-display font-extrabold text-3xl text-brand-dark mb-6">Our Story</h2>
          <div class="space-y-4 text-brand-grey leading-relaxed">
            <p>PackersHub was founded in 2018 in Nellore, Andhra Pradesh, with a simple mission: make moving stress-free for South Indian families. What started as a small local team has grown into a 150+ member organization serving 100+ cities across 5 states.</p>
            <p>Our founder experienced firsthand the chaos of unorganized moving companies — late arrivals, damaged goods, hidden charges, and zero accountability. PackersHub was built to fix all of that.</p>
            <p>Today, we combine technology (status tracking, real-time updates), trained professionals, and transparent pricing to deliver a moving experience that people actually trust and recommend.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { num:'2018', label:'Founded in Nellore, AP' },
            { num:'150+', label:'Trained Team Members' },
            { num:'5', label:'South Indian States' },
            { num:'100+', label:'Cities Covered' },
          ].map(s => (
            <div class="p-6 rounded-2xl bg-gradient-to-br from-orange-50 to-amber-50 border border-orange-100 text-center">
              <div class="font-display font-black text-3xl text-brand-orange mb-2">{s.num}</div>
              <div class="text-sm text-brand-grey font-medium">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display font-extrabold text-4xl text-brand-dark mb-4">Our Core Values</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon:'🛡️', title:'Safety First',   desc:'Every item wrapped, padded, and secured. 100% transit insurance on all moves.' },
          { icon:'💰', title:'Transparency',   desc:'Fixed quotes. No hidden charges. Invoice before we load a single box.' },
          { icon:'⏰', title:'Punctuality',    desc:'On-time pickup and delivery. Every time. No delays, no excuses.' },
          { icon:'🌟', title:'Excellence',     desc:'A written, all-inclusive quote and a Zero Damage Guarantee on every job. We settle for nothing less.' },
        ].map(v => (
          <div class="p-8 bg-white rounded-3xl shadow-card border border-gray-100 text-center card-lift">
            <div class="text-5xl mb-4">{v.icon}</div>
            <h3 class="font-bold text-xl text-brand-dark mb-3">{v.title}</h3>
            <p class="text-brand-grey text-sm leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact info -->
  <section class="py-16 bg-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-display font-bold text-3xl text-brand-dark mb-8">Get In Touch</h2>
      <div class="grid sm:grid-cols-2 gap-4 text-left">
        {[
          ['📍','Address','BV Nagar, Nellore, Andhra Pradesh — 524004'],
          ['📞','Phone','+91 77310 74075'],
          ['✉️','Email','info@packershub.in'],
          ['🌐','Website','www.packershub.in'],
        ].map(([icon,label,val]) => (
          <div class="flex gap-3 p-4 bg-gray-50 rounded-xl">
            <span class="text-2xl">{icon}</span>
            <div>
              <div class="font-bold text-sm text-brand-dark">{label}</div>
              <div class="text-sm text-brand-grey">{val}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <QuoteForm />
</BaseLayout>
