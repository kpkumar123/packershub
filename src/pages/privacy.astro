---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Privacy Policy — PackersHub"
  description="PackersHub Privacy Policy — How we collect, use, and protect your personal data. GDPR compliant."
  canonical="https://www.packershub.in/privacy"
>
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-brand-grey" role="list">
          <li><a href="/" class="hover:text-brand-orange">Home</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-brand-orange font-semibold" aria-current="page">Privacy Policy</li>
        </ol>
      </nav>
      <h1 class="font-display font-extrabold text-4xl text-brand-dark mb-4">Privacy Policy</h1>
      <p class="text-brand-grey mb-8"><time datetime="2025-01-01">Last updated: January 1, 2025</time></p>
      <div class="prose prose-lg max-w-none text-brand-grey">
        <h2>1. Information We Collect</h2>
        <p>We collect information you provide when filling our quote form: name, phone, email, moving details. We also collect usage data (pages visited, device type) via analytics.</p>
        <h2>2. How We Use Your Information</h2>
        <p>Your information is used to provide moving quotes, communicate about your move, and improve our services. We never sell your personal data to third parties.</p>
        <h2>3. Data Security</h2>
        <p>We use industry-standard encryption (HTTPS/TLS) and secure servers to protect your data. Access is restricted to authorized personnel only.</p>
        <h2>4. Contact</h2>
        <p>For privacy concerns: <a href="mailto:info@packershub.in" class="text-brand-orange">info@packershub.in</a> or call <a href="tel:+917731074075" class="text-brand-orange">+91 77310 74075</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>
