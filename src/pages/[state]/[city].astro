---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import citiesData from '../../data/cities.json';

export async function getStaticPaths() {
  const entries = await getCollection('cities');
  return entries.map(entry => ({
    params: {
      state: entry.data.stateSlug,
      city: entry.data.slug
    },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const faqItems = [
  { q: `How much does house shifting cost in ${d.city}?`, a: `Pricing depends on volume, distance, and specific requirements. PackersHub provides free all-inclusive quotes after a proper survey. Call or WhatsApp +91 77310 74075 for your estimate.` },
  { q: `Do you offer bike transport in ${d.city}?`, a: `Yes, PackersHub provides cradle-mounted bike transport from ${d.city} to all major cities in our 100-city South India network.` },
  { q: `Is transit insurance included?`, a: `Yes. Every PackersHub consignment carries goods-in-transit insurance as standard — for all moves including those from ${d.city}.` },
  { q: `Do you serve all areas within ${d.city}?`, a: `Our local teams cover all neighbourhoods in ${d.city}, including areas with narrow lanes and gated communities with security requirements.` },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question", "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---
<BaseLayout
  title={`Packers and Movers in ${d.city}, ${d.state} — PackersHub`}
  description={d.description}
  city={d.city}
  state={d.state}
  lat={d.lat}
  lng={d.lng}
  schema={faqSchema}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: d.state, url: `/${d.stateSlug}/` },
    { name: d.city, url: `/${d.stateSlug}/${d.slug}/` }
  ]}
>
  <!-- Hero -->
  <section class="bg-hero bg-grid py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <nav class="flex justify-center mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/" class="hover:text-brand-600 transition-colors">Home</a></li>
          <li class="text-slate-300">/</li>
          <li><a href={`/${d.stateSlug}/`} class="hover:text-brand-600 transition-colors">{d.state}</a></li>
          <li class="text-slate-300">/</li>
          <li class="text-slate-900 font-semibold">{d.city}</li>
        </ol>
      </nav>
      <h1 class="display-lg text-slate-900 font-display font-black mb-4">
        Packers and Movers in<br/><span class="gold-text">{d.city}</span>
      </h1>
      {d.tagline && <p class="text-slate-500 text-base mb-2 italic">{d.tagline}</p>}
      <p class="text-slate-600 text-lg max-w-2xl mx-auto mb-8">{d.description}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+917731074075" class="btn-gold py-3.5 px-8">📞 Call: +91 77310 74075</a>
        <a href={`https://wa.me/917731074075?text=${encodeURIComponent(`Hi PackersHub! I need help moving in ${d.city}.`)}`} target="_blank" rel="noopener" class="btn-ghost py-3.5 px-8">💬 WhatsApp Quote</a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <div class="bg-olive-700 py-3">
    <div class="max-w-5xl mx-auto px-4 flex flex-wrap justify-center gap-x-8 gap-y-2 text-white text-xs font-semibold">
      {['✅ All-Inclusive Pricing','🔒 Transit Insurance Included','📦 Professional Packing','⚡ 24/7 Support','🚚 GPS Tracked Vehicles'].map(b => <span>{b}</span>)}
    </div>
  </div>

  <!-- City Content -->
  <article class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none prose-headings:font-display prose-h2:text-brand-900 prose-h2:text-2xl prose-a:text-brand-600">
        <Content />
      </div>
    </div>
  </article>

  <!-- FAQ -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="section-title text-center mb-10 reveal">Frequently Asked Questions — {d.city}</h2>
      <div class="space-y-3">
        {faqItems.map((f, i) => (
          <div class="faq-item reveal" data-faq style={`transition-delay:${i*0.05}s`}>
            <div class="faq-question" data-faq-q>
              <span>{f.q}</span>
              <span class="faq-icon">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </span>
            </div>
            <div class="faq-answer" data-faq-a>
              <div class="faq-answer-inner">{f.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-16 bg-hero">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-slate-900 font-bold text-2xl font-display mb-4">Book Your {d.city} Move Today</h2>
      <p class="text-slate-600 mb-3">PackersHub · BV Nagar, Nellore, Andhra Pradesh 524004</p>
      <p class="text-slate-500 text-sm mb-8">Serving {d.city} as part of our 100-city South India network.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+917731074075" class="btn-gold py-3.5 px-8">📞 +91 77310 74075</a>
        <a href="https://wa.me/917731074075" target="_blank" rel="noopener" class="btn-ghost py-3.5 px-8">💬 WhatsApp</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
document.querySelectorAll('[data-faq]').forEach(item => {
  const q = item.querySelector('[data-faq-q]');
  const a = item.querySelector('[data-faq-a]');
  q?.addEventListener('click', () => {
    const isOpen = a?.classList.contains('open');
    document.querySelectorAll('[data-faq-a]').forEach(el => el.classList.remove('open'));
    document.querySelectorAll('[data-faq]').forEach(el => el.classList.remove('open'));
    if (!isOpen) { a?.classList.add('open'); item.classList.add('open'); }
  });
});
</script>
