---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import Services from '../../components/Services.astro';
import Testimonials from '../../components/Testimonials.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import FAQ from '../../components/FAQ.astro';
import CitiesGrid from '../../components/CitiesGrid.astro';
import states from '../../data/states.json';
import cities from '../../data/cities.json';

export async function getStaticPaths() {
  return states.map(s => ({
    params: { state: s.slug },
    props:  { state: s },
  }));
}

const { state } = Astro.props;
const stateCities = cities.filter(c => c.state === state.slug);

const stateSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MovingCompany",
      "@id": `https://www.packershub.in/${state.slug}/#organization`,
      "name": `PackersHub — Packers & Movers in ${state.name}`,
      "url": `https://www.packershub.in/${state.slug}`,
      "telephone": "+917731074075",
      "areaServed": { "@type": "State", "name": state.name },
      "address": { "@type": "PostalAddress", "addressRegion": state.name, "addressCountry": "IN" },
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "2847", "bestRating": "5" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.packershub.in/" },
        { "@type": "ListItem", "position": 2, "name": state.name, "item": `https://www.packershub.in/${state.slug}` }
      ]
    }
  ]
};
---
<BaseLayout
  title={`Packers & Movers in ${state.name} — PackersHub | Best ${state.abbr} Movers`}
  description={`Best packers and movers in ${state.name}. PackersHub serves all 20 major ${state.name} cities. Trusted by 15,000+ families. 100% insured · GPS tracked · ★4.9 rated · Call +91 77310 74075`}
  keywords={state.keywords.join(', ')}
  canonical={`https://www.packershub.in/${state.slug}`}
  schema={stateSchema}
  stateName={state.name}
  geoRegion={`IN-${state.abbr}`}
>

  <!-- HERO -->
  <section class="relative overflow-hidden hero-bg pt-12 pb-20 lg:pt-20 lg:pb-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-brand-grey" role="list">
          <li><a href="/" class="hover:text-brand-orange transition-colors">Home</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-brand-orange font-semibold" aria-current="page">{state.name}</li>
        </ol>
      </nav>

      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="animate-fade-up">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white shadow-card border border-orange-100 mb-6">
            <span class="text-2xl">{state.flag}</span>
            <span class="text-sm font-bold text-brand-dark">Serving all {state.name} cities</span>
          </div>
          <h1 class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl leading-tight text-brand-dark mb-5">
            Packers &amp; Movers<br/>in <span class="text-gradient">{state.name}</span>
          </h1>
          <p class="text-lg text-brand-grey mb-8 max-w-lg leading-relaxed">{state.hero}</p>
          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a href="#quote" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full bg-gradient-to-r from-brand-orange to-brand-gold text-white font-bold text-base shadow-cta hover:shadow-glow hover:scale-[1.02] transition-all btn-shine">
              🚚 Get Free Quote
            </a>
            <a href="tel:+917731074075" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full bg-white border-2 border-brand-orange/30 text-brand-dark font-bold hover:border-brand-orange hover:bg-orange-50 transition-all">
              📞 +91 77310 74075
            </a>
          </div>
          <div class="flex flex-wrap gap-4">
            {[['20+','Cities in '+state.abbr],['4.9★','Rating'],['100%','Insured'],['24/7','Support']].map(([n,l]) => (
              <div class="text-center">
                <div class="font-display font-black text-2xl text-brand-dark">{n}</div>
                <div class="text-xs text-brand-grey">{l}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- State info card -->
        <div class="animate-fade-up bg-white rounded-3xl shadow-2xl border border-gray-100 p-8" style="animation-delay:.15s">
          <h2 class="font-display font-bold text-2xl text-brand-dark mb-6">Why PackersHub for {state.name}?</h2>
          <ul class="space-y-4">
            {[
              '🏆 7 years serving '+state.name+' customers',
              '📍 20 major cities covered',
              '🛡️ 100% transit insurance on all moves',
              '📱 Real-time GPS tracking',
              '💰 Transparent pricing — no hidden costs',
              '⚡ 24×7 customer support in local language',
              '✅ GST-compliant billing',
              '🌟 4.9★ average from 2,847+ reviews',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm text-brand-grey">
                <span class="text-lg shrink-0">{item.substring(0,2)}</span>
                <span>{item.substring(2)}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <TrustStrip />

  <!-- About state content -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none">
        <h2 class="font-display font-extrabold text-3xl text-brand-dark mb-6">
          Best Packers &amp; Movers in {state.name} — PackersHub
        </h2>
        <p class="text-brand-grey leading-relaxed">{state.description}</p>
        <div class="grid md:grid-cols-3 gap-6 mt-10 not-prose">
          {[
            { icon:'🏠', title:'Household Moving', desc:'1BHK to 5BHK+ home shifts across '+state.name },
            { icon:'🏢', title:'Office Relocation', desc:'Zero-downtime corporate moves in '+state.abbr },
            { icon:'🚗', title:'Vehicle Transport', desc:'Cars & bikes shipped safely across '+state.name },
          ].map(s => (
            <div class="p-6 rounded-2xl bg-orange-50 border border-orange-100">
              <div class="text-3xl mb-3">{s.icon}</div>
              <h3 class="font-bold text-brand-dark mb-2">{s.title}</h3>
              <p class="text-sm text-brand-grey">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Cities Grid -->
  <CitiesGrid cities={stateCities} stateSlug={state.slug} heading={`20 Cities in ${state.name}`} />

  <Services />
  <Testimonials />
  <QuoteForm />
  <FAQ />

</BaseLayout>
