---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { resolveBlogImage } from '../../utils/blogImages';
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
const heroImage = post.data.image ? resolveBlogImage(post.data.image) : undefined;
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  ogImage={post.data.image}
  publishDate={post.data.pubDate}
  modifiedDate={post.data.updatedDate}
  author={post.data.author}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog/' },
    { name: post.data.title, url: `/blog/${post.id}/` }
  ]}
>
  <section class="bg-hero bg-grid py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <span class="inline-block bg-blue-50 border border-blue-200 rounded-full px-4 py-1.5 text-slate-700 text-xs font-bold uppercase tracking-wide mb-5">{post.data.category}</span>
      <h1 class="display-lg text-slate-900 font-display font-black mb-6">{post.data.title}</h1>
      <div class="flex items-center justify-center gap-4 text-slate-500 text-sm">
        <span>{post.data.author}</span>
        <span>·</span>
        <span>{new Date(post.data.pubDate).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'})}</span>
        <span>·</span>
        <span>{post.data.readTime} min read</span>
      </div>
    </div>
  </section>
  {heroImage && (
    <div class="max-w-3xl mx-auto px-4 -mt-10 relative z-10">
      <Image
        src={heroImage}
        alt={post.data.title}
        class="w-full rounded-2xl shadow-2xl"
        width={1200}
        height={630}
        loading="eager"
      />
    </div>
  )}
  <article class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <div class="prose prose-lg max-w-none prose-headings:font-display prose-h2:text-brand-900 prose-a:text-brand-600">
        <Content />
      </div>
      <div class="mt-16 p-8 bg-brand-50 rounded-2xl border border-brand-100 text-center">
        <h3 class="font-bold text-xl text-brand-900 font-display mb-3">Need Help with Your Move?</h3>
        <p class="text-slate-600 mb-6">PackersHub serves 100 cities across South India with professional, transparent relocation services.</p>
        <div class="flex justify-center gap-4 flex-wrap">
          <a href="tel:+917731074075" class="btn-primary">📞 Call: +91 77310 74075</a>
          <a href="https://wa.me/917731074075" target="_blank" rel="noopener" class="btn-secondary">💬 WhatsApp Quote</a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
