---
import states from '../data/states.json';
import cities from '../data/cities.json';

const topCities = ['visakhapatnam','vijayawada','hyderabad','chennai','bangalore','kochi','nellore','tirupati','warangal','coimbatore','mysore','madurai'];
const featured = cities.filter(c => topCities.includes(c.slug));
---
<footer class="bg-gradient-to-br from-[#0D1117] via-[#111827] to-[#0D1117] text-white" role="contentinfo">

  <!-- Main Footer Grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-5 group" aria-label="PackersHub Home">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-orange to-brand-gold grid place-items-center shadow-glow group-hover:scale-105 transition-transform">
            <span class="font-display font-black text-white text-sm">PH</span>
          </div>
          <div>
            <div class="font-display font-bold text-xl tracking-tight">Packers<span class="text-brand-orange">Hub</span></div>
            <div class="text-[10px] text-gray-400 uppercase tracking-wider">South India's #1 Movers</div>
          </div>
        </a>

        <p class="text-sm text-gray-400 leading-relaxed mb-6">
          Trusted by 15,000+ families and businesses across South India. Professional packing, safe transport, on-time delivery — every time.
        </p>

        <!-- Trust badges -->
        <div class="flex flex-col gap-2 mb-6">
          <div class="flex items-center gap-2 text-sm">
            <span class="text-yellow-400">★★★★★</span>
            <span class="text-gray-300 font-semibold">4.9/5</span>
            <span class="text-gray-500 text-xs">— 2,847 Reviews</span>
          </div>
          <div class="flex items-center gap-2 text-xs text-gray-400">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
            Available 24×7 · 365 Days
          </div>
          <div class="text-xs text-gray-400">🛡️ 100% Transit Insured · GPS Tracked</div>
        </div>

        <!-- Social Links -->
        <div class="flex gap-3">
          <a href="https://wa.me/917731074075" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp PackersHub"
             class="w-9 h-9 rounded-full bg-[#25D366]/20 hover:bg-[#25D366] border border-[#25D366]/30 grid place-items-center transition-all duration-200 group/s">
            <svg class="w-4 h-4 text-[#25D366] group-hover/s:text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
          <a href="tel:+917731074075" aria-label="Call PackersHub"
             class="w-9 h-9 rounded-full bg-brand-orange/20 hover:bg-brand-orange border border-brand-orange/30 grid place-items-center transition-all duration-200 group/s">
            <svg class="w-4 h-4 text-brand-orange group-hover/s:text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.36 11.36 0 003.58.57 1 1 0 011 1v3.5a1 1 0 01-1 1A17 17 0 013 5a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z"/></svg>
          </a>
          <a href="mailto:info@packershub.in" aria-label="Email PackersHub"
             class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 border border-white/10 grid place-items-center transition-all duration-200">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-display font-bold text-sm uppercase tracking-widest text-brand-gold mb-5">Quick Links</h3>
        <ul class="space-y-2.5 text-sm text-gray-400">
          {[
            ['/', 'Home'],
            ['/about', 'About Us'],
            ['/services', 'Our Services'],
            ['/blog', 'Blog & Tips'],
            ['/contact', 'Contact Us'],
            ['/privacy', 'Privacy Policy'],
            ['/terms', 'Terms & Conditions'],
            ['/#quote', 'Get Free Quote'],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="hover:text-brand-orange transition-colors duration-150 flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-brand-orange/50"></span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- States + Top Cities -->
      <div>
        <h3 class="font-display font-bold text-sm uppercase tracking-widest text-brand-gold mb-5">States We Serve</h3>
        <ul class="space-y-2 text-sm text-gray-400 mb-6">
          {states.map(s => (
            <li>
              <a href={`/${s.slug}`} class="hover:text-brand-orange transition-colors duration-150 flex items-center gap-2">
                <span>{s.flag}</span>
                {s.name}
              </a>
            </li>
          ))}
        </ul>
        <h3 class="font-display font-bold text-sm uppercase tracking-widest text-brand-gold mb-3">Top Cities</h3>
        <ul class="grid grid-cols-2 gap-x-3 gap-y-1.5 text-xs text-gray-400">
          {featured.map(c => (
            <li>
              <a href={`/${c.state}/${c.slug}`} class="hover:text-brand-orange transition-colors duration-150 truncate block">
                {c.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display font-bold text-sm uppercase tracking-widest text-brand-gold mb-5">Contact Us</h3>
        <address class="not-italic space-y-4 text-sm text-gray-400">
          <div class="flex items-start gap-3">
            <span class="text-brand-orange mt-0.5">📍</span>
            <div>
              <p class="text-white font-semibold mb-0.5">Headquarters</p>
              <p>BV Nagar, Nellore<br/>Andhra Pradesh — 524004<br/>India</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-brand-orange">📞</span>
            <div>
              <p class="text-white font-semibold mb-0.5">Phone / WhatsApp</p>
              <a href="tel:+917731074075" class="hover:text-brand-orange transition-colors">+91 77310 74075</a>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-brand-orange">✉️</span>
            <div>
              <p class="text-white font-semibold mb-0.5">Email</p>
              <a href="mailto:info@packershub.in" class="hover:text-brand-orange transition-colors">info@packershub.in</a>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-brand-orange">🌐</span>
            <div>
              <p class="text-white font-semibold mb-0.5">Website</p>
              <a href="https://www.packershub.in" class="hover:text-brand-orange transition-colors">www.packershub.in</a>
            </div>
          </div>
        </address>

        <!-- Quick CTA -->
        <div class="mt-6 p-4 rounded-2xl bg-gradient-to-br from-brand-orange/10 to-brand-gold/10 border border-brand-orange/20">
          <p class="text-xs font-bold text-white mb-2">Need Help Right Now?</p>
          <a href="tel:+917731074075"
             class="block text-center py-2.5 rounded-full bg-gradient-to-r from-brand-orange to-brand-gold text-white font-bold text-sm btn-shine">
            📞 Call Now — Free Quote
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <p>© {new Date().getFullYear()} PackersHub.in — All rights reserved. GST Registered.</p>
      <p class="flex items-center gap-2">
        <span>Made with ❤️ for South India</span>
        <span class="text-gray-600">·</span>
        <span>AP · Telangana · TN · Karnataka · Kerala</span>
      </p>
      <p>
        <a href="/privacy" class="hover:text-brand-orange transition-colors">Privacy</a>
        <span class="mx-1">·</span>
        <a href="/terms" class="hover:text-brand-orange transition-colors">Terms</a>
        <span class="mx-1">·</span>
        <a href="/sitemap-index.xml" class="hover:text-brand-orange transition-colors">Sitemap</a>
      </p>
    </div>
  </div>
</footer>
