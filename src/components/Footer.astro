---
import statesData from '../data/states.json';
const year = new Date().getFullYear();
---
<footer class="site-footer" itemscope itemtype="https://schema.org/WPFooter">
  <!-- Top Section -->
  <div class="border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 lg:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-10">
        
        <!-- Brand Column -->
        <div class="lg:col-span-2">
          <a href="/" class="flex items-center gap-2.5 mb-5" aria-label="PackersHub">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-600 to-brand-700 flex items-center justify-center">
              <span class="text-white font-black text-lg font-display">P</span>
            </div>
            <div>
              <div class="text-white font-black text-xl font-display tracking-tight">PackersHub</div>
              <div class="text-brand-300 text-xs font-semibold tracking-widest">SOUTH INDIA</div>
            </div>
          </a>
          <p class="text-slate-400 text-sm leading-relaxed mb-6 max-w-xs">
            Trusted packers and movers across 100 cities in South India. Professional, transparent, and reliable relocation services since day one.
          </p>
          <!-- NAP -->
          <div class="space-y-3" itemscope itemtype="https://schema.org/PostalAddress">
            <div class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-slate-400">
                <span itemprop="streetAddress">BV Nagar</span>, 
                <span itemprop="addressLocality">Nellore</span>,
                <span itemprop="addressRegion">Andhra Pradesh</span> — 
                <span itemprop="postalCode">524004</span>
              </span>
            </div>
            <div class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href="tel:+917731074075" class="text-slate-300 hover:text-white transition-colors font-medium" itemprop="telephone">+91 77310 74075</a>
            </div>
            <div class="flex gap-3 text-sm">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <a href="mailto:info@packershub.in" class="text-slate-300 hover:text-white transition-colors">info@packershub.in</a>
            </div>
          </div>
          <!-- Trust badges (honest — no fabricated review counts) -->
          <div class="flex items-center gap-2 mt-5 pt-5 border-t border-white/10">
            <span class="text-slate-300 text-sm font-medium">📦 100+ Cities · 5 States · Goods-in-Transit Insurance</span>
          </div>
        </div>

        <!-- Services -->
        <div>
          <h3 class="text-white font-bold text-sm tracking-widest uppercase mb-4">Services</h3>
          <ul class="space-y-2.5">
            {['House Shifting','Office Relocation','Bike Transport','Car Carrier Service','Warehouse Storage','Intercity Moves','Interstate Packers','Corporate Relocation'].map(s => (
              <li><a href="/services/" class="text-slate-400 hover:text-white text-sm transition-colors">{s}</a></li>
            ))}
          </ul>
        </div>

        <!-- States -->
        <div>
          <h3 class="text-white font-bold text-sm tracking-widest uppercase mb-4">States</h3>
          <ul class="space-y-2.5">
            {statesData.map(s => (
              <li><a href={s.url} class="text-slate-400 hover:text-white text-sm transition-colors">{s.name}</a></li>
            ))}
          </ul>
          <h3 class="text-white font-bold text-sm tracking-widest uppercase mt-6 mb-4">Company</h3>
          <ul class="space-y-2.5">
            {[['Get a Quote','/booking/'],['About Us','/about/'],['Blog','/blog/'],['Contact','/contact/'],['Privacy Policy','/privacy/'],['Terms of Service','/terms/']].map(([label, href]) => (
              <li><a href={href} class="text-slate-400 hover:text-white text-sm transition-colors">{label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Top Cities 1 -->
        <div>
          <h3 class="text-white font-bold text-sm tracking-widest uppercase mb-4">AP & TS Cities</h3>
          <ul class="space-y-2">
            {['Visakhapatnam','Vijayawada','Guntur','Nellore','Tirupati','Hyderabad','Warangal','Karimnagar','Nizamabad','Khammam'].map(city => {
              const slug = city.toLowerCase().replace(/\s+/g,'-');
              const stateSlug = ['Visakhapatnam','Vijayawada','Guntur','Nellore','Tirupati'].includes(city) ? 'andhra-pradesh' : 'telangana';
              return (
                <li><a href={`/${stateSlug}/${slug}/`} class="text-slate-400 hover:text-white text-xs transition-colors">{city}</a></li>
              )
            })}
          </ul>
        </div>

        <!-- Top Cities 2 -->
        <div>
          <h3 class="text-white font-bold text-sm tracking-widest uppercase mb-4">TN, KA & KL Cities</h3>
          <ul class="space-y-2">
            {[['Chennai','tamil-nadu'],['Coimbatore','tamil-nadu'],['Madurai','tamil-nadu'],['Bengaluru','karnataka'],['Mysuru','karnataka'],['Mangaluru','karnataka'],['Kochi','kerala'],['Thiruvananthapuram','kerala'],['Kozhikode','kerala'],['Thrissur','kerala']].map(([city, state]) => {
              const slug = city.toLowerCase().replace(/\s+/g,'-');
              return (
                <li><a href={`/${state}/${slug}/`} class="text-slate-400 hover:text-white text-xs transition-colors">{city}</a></li>
              )
            })}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-sm text-center md:text-left">
        © {year} PackersHub.in — All rights reserved. Trusted packers and movers across 100 cities in South India.
      </p>
      <div class="flex items-center gap-5">
        <a href="/privacy/" class="text-slate-500 hover:text-slate-300 text-xs transition-colors">Privacy Policy</a>
        <a href="/terms/" class="text-slate-500 hover:text-slate-300 text-xs transition-colors">Terms</a>
        <a href="/sitemap-index.xml" class="text-slate-500 hover:text-slate-300 text-xs transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
