---
// FAQ.astro — MODULE 15 AEO Voice Search Optimized FAQs
const { city } = Astro.props;

const faqs = [
  {
    q: `How much do packers and movers cost${city ? ` in ${city}` : ''}?`,
    a: `Local moves (within city) start at ₹3,500–₹8,000 for 1–2 BHK. Intercity moves range ₹10,000–₹50,000 depending on distance, goods volume, and floor access. ${city ? `For ${city} specifically, ` : ''}our team provides an exact quote after a free assessment. All prices include packing materials, labour, transport, and insurance.`,
  },
  {
    q: 'Are my belongings insured during transit?',
    a: 'Yes! All PackersHub shipments include comprehensive transit insurance covering accidental damage, loss, and theft at no extra cost. For high-value items like artwork, antiques, or pianos, we recommend additional declared-value coverage which can be added to any package.',
  },
  {
    q: 'How far in advance should I book packers and movers?',
    a: 'We recommend booking 7–15 days in advance for best availability and rates. Month-end dates (25th–31st) get booked early. We also offer urgent same-day and next-day service for emergency moves — call +91 77310 74075 for urgent bookings.',
  },
  {
    q: 'Do you provide packing materials?',
    a: 'Yes — all packing materials are included in our quotes: bubble wrap, corrugated boxes, stretch wrap, foam padding, moving blankets, and specialized crating for fragile items. No need to arrange anything separately.',
  },
  {
    q: 'Can I track my shipment in real time?',
    a: 'Absolutely. We share a live GPS tracking link via WhatsApp once your goods are loaded onto our truck. You can track exact location, estimated arrival time, and get automated alerts at key milestones.',
  },
  {
    q: 'What happens if something gets damaged during the move?',
    a: 'In the rare event of damage, our insurance claim process begins immediately. We document, assess, and process claims within 7 working days. Our damage rate is under 0.02% across 15,000+ moves, backed by our Zero Damage Guarantee.',
  },
  {
    q: 'Do you offer storage if my new home is not ready?',
    a: 'Yes. We have climate-controlled, CCTV-monitored warehouses across South India. Short-term (weekly) and long-term (monthly) storage is available. Your goods are fully insured during storage too.',
  },
  {
    q: `Which areas do you serve${city ? ` from ${city}` : ' in South India'}?`,
    a: `PackersHub serves 100+ cities across 5 South Indian states — Andhra Pradesh, Telangana, Tamil Nadu, Karnataka, and Kerala. We also handle intercity moves to all major cities in North India and international relocations worldwide.`,
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---
<section class="py-20 bg-white" aria-labelledby="faq-heading">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 reveal">
      <span class="inline-block px-4 py-1.5 rounded-full bg-sky-100 text-accent-sky text-sm font-bold mb-4 uppercase tracking-wide">
        FAQ
      </span>
      <h2 id="faq-heading" class="font-display text-4xl lg:text-5xl font-extrabold text-brand-dark mb-4">
        Frequently Asked Questions
      </h2>
      <p class="text-brand-grey">Everything you need to know about moving with PackersHub{city ? ` in ${city}` : ''}</p>
    </div>

    <div class="space-y-3">
      {faqs.map((f, i) => (
        <details
          class="group bg-gray-50 hover:bg-orange-50/50 rounded-2xl border border-gray-100 hover:border-orange-100 overflow-hidden transition-colors duration-200 reveal"
          open={i === 0}
          style={`animation-delay:${i*.05}s`}
        >
          <summary class="cursor-pointer px-6 py-5 flex items-center justify-between gap-4 font-semibold text-brand-dark hover:text-brand-orange transition-colors">
            <span class="text-sm sm:text-base">{f.q}</span>
            <span class="text-brand-orange shrink-0 group-open:rotate-45 transition-transform duration-300 text-2xl font-light">+</span>
          </summary>
          <div class="px-6 pb-5 text-brand-grey text-sm leading-relaxed border-t border-gray-100">
            <p class="pt-3">{f.a}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="mt-10 text-center reveal">
      <p class="text-brand-grey text-sm mb-4">Still have questions?</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="tel:+917731074075" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-brand-orange to-brand-gold text-white font-bold btn-shine">
          📞 Call Us Now
        </a>
        <a href="https://wa.me/917731074075?text=Hi%20PackersHub%2C%20I%20have%20a%20question" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-[#25D366]/10 hover:bg-[#25D366] border border-[#25D366]/30 text-[#25D366] hover:text-white font-bold transition-colors">
          💬 Ask on WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
