---
// SEOHead.astro — MODULE 04-16 (All Meta, OG, Twitter, GEO, AEO, AIO, SXO)
const {
  title = 'PackersHub — #1 Packers & Movers in South India | Free Quote',
  description = 'South India\'s most trusted packers and movers. 100+ cities · AP, Telangana, Tamil Nadu, Karnataka, Kerala · 100% insured · GPS tracked · ★4.9 rated · Call +91 77310 74075',
  keywords = 'packers and movers south india, best movers nellore, relocation services AP telangana, household shifting south india, office movers, vehicle transport south india',
  image = '/og-image.jpg',
  canonical = Astro.url.href,
  schema,
  cityName,
  stateName,
  geoLat = 14.4426,
  geoLng  = 79.9865,
  geoRegion = 'IN-AP',
  geoPlace  = 'Nellore',
  articleDate,
  articleModified,
} = Astro.props;

const ogImage = image.startsWith('http') ? image : `https://www.packershub.in${image}`;
const pageType = articleDate ? 'article' : 'website';
---

<!-- ═══ CHARSET & VIEWPORT ═══ -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />

<!-- ═══ MODULE 04 — PRIMARY META ═══ -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content="PackersHub" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="googlebot" content="index, follow, max-image-preview:large" />
<meta name="bingbot" content="index, follow" />
<link rel="canonical" href={canonical} />
<meta name="format-detection" content="telephone=yes" />
<meta name="theme-color" content="#E8510A" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#0D1117" media="(prefers-color-scheme: dark)" />

<!-- ═══ MODULE 05 — OPEN GRAPH ═══ -->
<meta property="og:type" content={pageType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="PackersHub — South India's #1 Packers & Movers" />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="PackersHub" />
<meta property="og:locale" content="en_IN" />
{articleDate && <meta property="article:published_time" content={articleDate} />}
{articleModified && <meta property="article:modified_time" content={articleModified} />}

<!-- ═══ MODULE 06 — TWITTER CARD ═══ -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@packershub" />
<meta name="twitter:creator" content="@packershub" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content="PackersHub Movers" />

<!-- ═══ MODULE 07 — GEO TAGS (Local SEO) ═══ -->
<meta name="geo.region" content={geoRegion} />
<meta name="geo.placename" content={cityName || geoPlace} />
<meta name="geo.position" content={`${geoLat};${geoLng}`} />
<meta name="ICBM" content={`${geoLat}, ${geoLng}`} />
<meta name="DC.title" content={title} />
<meta name="DC.language" content="en-IN" />

<!-- ═══ MODULE 08 — AEO / VOICE SEARCH HINTS ═══ -->
<meta name="speakable" content={description} />
<meta name="content-language" content="en-IN" />
<meta name="language" content="English" />
<meta name="revisit-after" content="7 days" />

<!-- ═══ MODULE 09 — AIO / AI ENGINE OPTIMIZATION ═══ -->
<meta name="ai-content-declaration" content="human-curated" />
<meta name="ai-purpose" content="business-information" />
<meta name="ai-company-type" content="MovingCompany" />
<meta name="ai-service-area" content="South India — Andhra Pradesh, Telangana, Tamil Nadu, Karnataka, Kerala" />
<meta name="ai-contact" content="phone:+917731074075, whatsapp:+917731074075" />
<meta name="ai-rating" content="4.9/5 based on 2847 reviews" />

<!-- ═══ MODULE 10 — PERFORMANCE: RESOURCE HINTS ═══ -->
<link rel="dns-prefetch" href="//fonts.googleapis.com" />
<link rel="dns-prefetch" href="//fonts.gstatic.com" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- Fonts: critical preload -->
<link rel="preload" as="style"
  href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" />
<link rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
  media="print" onload="this.media='all'" />
<noscript>
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" />
</noscript>

<!-- ═══ MODULE 11 — PWA & ICONS ═══ -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="apple-touch-icon" href="/icon-192.png" />
<link rel="manifest" href="/manifest.webmanifest" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="PackersHub" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="msapplication-TileColor" content="#E8510A" />
<meta name="msapplication-TileImage" content="/icon-192.png" />

<!-- ═══ MODULE 12 — BASE ORGANIZATION SCHEMA ═══ -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MovingCompany",
      "@id": "https://www.packershub.in/#organization",
      "name": "PackersHub",
      "alternateName": ["Packers Hub", "PackersHub.in"],
      "description": "South India's #1 trusted packers and movers. 100+ cities, 5 states, 15,000+ happy customers.",
      "url": "https://www.packershub.in",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.packershub.in/favicon.svg",
        "width": 100,
        "height": 100
      },
      "image": "https://www.packershub.in/og-image.jpg",
      "telephone": "+917731074075",
      "email": "info@packershub.in",
      "foundingDate": "2018",
      "numberOfEmployees": { "@type": "QuantitativeValue", "value": 150 },
      "priceRange": "₹₹",
      "currenciesAccepted": "INR",
      "paymentAccepted": "Cash, UPI, Net Banking, Card",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "BV Nagar",
        "addressLocality": "Nellore",
        "addressRegion": "Andhra Pradesh",
        "postalCode": "524004",
        "addressCountry": "IN"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 14.4426,
        "longitude": 79.9865
      },
      "areaServed": [
        { "@type": "State", "name": "Andhra Pradesh" },
        { "@type": "State", "name": "Telangana" },
        { "@type": "State", "name": "Tamil Nadu" },
        { "@type": "State", "name": "Karnataka" },
        { "@type": "State", "name": "Kerala" }
      ],
      "serviceType": [
        "Household Shifting", "Office Relocation", "Vehicle Transport",
        "Storage & Warehousing", "International Moving", "Special Item Handling"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "2847",
        "bestRating": "5",
        "worstRating": "1"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "00:00",
        "closes": "23:59"
      },
      "sameAs": [
        "https://wa.me/917731074075",
        "https://www.facebook.com/packershub",
        "https://www.instagram.com/packershub"
      ],
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "telephone": "+917731074075",
          "contactType": "customer service",
          "areaServed": "IN",
          "availableLanguage": ["English", "Telugu", "Tamil", "Kannada", "Malayalam", "Hindi"],
          "contactOption": "TollFree",
          "hoursAvailable": {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
            "opens": "00:00",
            "closes": "23:59"
          }
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://www.packershub.in/#website",
      "url": "https://www.packershub.in",
      "name": "PackersHub",
      "description": "South India's #1 Packers & Movers — 100 Cities, 5 States",
      "publisher": { "@id": "https://www.packershub.in/#organization" },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://www.packershub.in/?s={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      },
      "inLanguage": "en-IN"
    }
  ]
})} />

<!-- ═══ PAGE-SPECIFIC SCHEMA ═══ -->
{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}
