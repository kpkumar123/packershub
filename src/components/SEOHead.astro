---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  city?: string;
  state?: string;
  lat?: number;
  lng?: number;
  noindex?: boolean;
  schema?: object;
  breadcrumbs?: { name: string; url: string }[];
  publishDate?: Date;
  modifiedDate?: Date;
  author?: string;
}
const {
  title, description, canonical, ogImage = '/og-image.jpg',
  type = 'website', city, state, lat, lng,
  noindex = false, schema, breadcrumbs, publishDate, modifiedDate, author
} = Astro.props;

const siteUrl = 'https://www.packershub.in';
const fullTitle = title.includes('PackersHub') ? title : `${title} | PackersHub`;
const fullCanonical = canonical || Astro.url.href;
const phone = '+91 77310 74075';

// Core Organization Schema
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "MovingCompany",
  "@id": `${siteUrl}/#organization`,
  "name": "PackersHub",
  "alternateName": ["PackersHub.in", "Packers Hub South India"],
  "url": siteUrl,
  "telephone": phone,
  "email": "info@packershub.in",
  "description": "Trusted packers and movers across 100 cities in South India — Andhra Pradesh, Telangana, Tamil Nadu, Karnataka, Kerala. All-inclusive pricing, transit insurance, 24/7 support.",
  "logo": {
    "@type": "ImageObject",
    "url": `${siteUrl}/icon-512.png`,
    "width": 512, "height": 512
  },
  "image": `${siteUrl}/og-image.jpg`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "BV Nagar",
    "addressLocality": "Nellore",
    "addressRegion": "Andhra Pradesh",
    "postalCode": "524004",
    "addressCountry": "IN"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 14.4426, "longitude": 79.9865 },
  "areaServed": [
    { "@type": "State", "name": "Andhra Pradesh" },
    { "@type": "State", "name": "Telangana" },
    { "@type": "State", "name": "Tamil Nadu" },
    { "@type": "State", "name": "Karnataka" },
    { "@type": "State", "name": "Kerala" }
  ],
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "00:00", "closes": "23:59"
  }],
  "priceRange": "₹₹",
  "currenciesAccepted": "INR",
  "paymentAccepted": "Cash, Credit Card, Debit Card, UPI, NEFT",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Relocation Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"House Shifting","description":"Complete home relocation with packing, loading, transport and unpacking."}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Office Relocation","description":"Zero-downtime office moves with secure IT and document handling."}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Bike Transport","description":"Cradle-mounted two-wheeler transport across 100 South Indian cities."}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Car Carrier Service","description":"Open and enclosed car transport with full insurance coverage."}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Warehouse Storage","description":"Secure climate-controlled storage with first 48 hours free."}}
    ]
  }
};

// Local Business Schema for city pages
const localSchema = city && lat && lng ? {
  "@context": "https://schema.org",
  "@type": "MovingCompany",
  "@id": `${fullCanonical}#local`,
  "name": `PackersHub — Packers and Movers in ${city}`,
  "telephone": phone,
  "url": fullCanonical,
  "description": `Professional packers and movers in ${city}, ${state}. All-inclusive pricing, transit insurance, and 24/7 support. Call +91 77310 74075.`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city,
    "addressRegion": state,
    "addressCountry": "IN"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": lat, "longitude": lng },
  "areaServed": { "@type": "City", "name": city },
  "parentOrganization": { "@id": `${siteUrl}/#organization` }
} : null;

// Breadcrumb Schema
const breadcrumbSchema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": b.name,
    "item": `${siteUrl}${b.url}`
  }))
} : null;

// Collect all schemas
const allSchemas = [
  orgSchema,
  localSchema,
  breadcrumbSchema,
  schema
].filter(Boolean);
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />

<title>{fullTitle}</title>
<meta name="description" content={description} />

<!-- Canonical -->
<link rel="canonical" href={fullCanonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={fullCanonical} />
<meta property="og:image" content={`https://www.packershub.in${ogImage}`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="PackersHub — Packers and Movers South India" />
<meta property="og:site_name" content="PackersHub" />
<meta property="og:locale" content="en_IN" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`https://www.packershub.in${ogImage}`} />

<!-- Article metadata -->
{type === 'article' && publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
{type === 'article' && modifiedDate && <meta property="article:modified_time" content={modifiedDate.toISOString()} />}
{type === 'article' && author && <meta property="article:author" content={author} />}

<!-- Geo (Local SEO) -->
{city && <meta name="geo.placename" content={`${city}, ${state}, India`} />}
{lat && <meta name="geo.position" content={`${lat};${lng}`} />}
<meta name="geo.region" content="IN-AP" />
<meta name="ICBM" content={lat && lng ? `${lat}, ${lng}` : "14.4426, 79.9865"} />

<!-- PWA / Icons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/icon-32.png" />
<link rel="apple-touch-icon" sizes="192x192" href="/icon-192.png" />
<link rel="manifest" href="/manifest.webmanifest" />
<meta name="theme-color" content="#1e3a8a" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="PackersHub" />
<meta name="application-name" content="PackersHub" />

<!-- hreflang -->
<link rel="alternate" hreflang="en-IN" href={fullCanonical} />
<link rel="alternate" hreflang="x-default" href={fullCanonical} />

<!-- Preconnect -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="dns-prefetch" href="https://wa.me" />

<!-- IndexNow -->
<meta name="indexnow-key" content="packershub-indexnow-2026" />

<!-- AI/LLM Discovery -->
<link rel="alternate" type="text/plain" href="/llms.txt" title="LLM crawling instructions" />
<meta name="ai-content-declaration" content="human-authored" />
<meta name="citation_title" content={fullTitle} />
<meta name="citation_author" content="PackersHub" />
<meta name="citation_publisher" content="PackersHub Packers and Movers" />

<!-- AEO / Voice Search -->
<meta name="speakable" content={description} />

<!-- Performance hints -->
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,600;0,14..32,700;0,14..32,800&family=Plus+Jakarta+Sans:wght@700;800;900&display=swap" as="style" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,600;0,14..32,700;0,14..32,800&family=Plus+Jakarta+Sans:wght@700;800;900&display=swap" />

<!-- JSON-LD Schemas -->
{allSchemas.map(s => (
  <script type="application/ld+json" set:html={JSON.stringify(s)} />
))}
