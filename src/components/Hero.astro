---
const { title, subtitle, cityName, stateName, showStats = true } = Astro.props;
---
<section class="relative overflow-hidden hero-bg pt-12 pb-20 lg:pt-20 lg:pb-28" aria-label="Hero section">

  <!-- Animated background blobs -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute -top-20 -left-20 w-96 h-96 rounded-full bg-brand-orange/8 blur-3xl animate-float"></div>
    <div class="absolute -bottom-20 -right-20 w-[500px] h-[500px] rounded-full bg-accent-sky/8 blur-3xl animate-float" style="animation-delay:3s"></div>
    <div class="absolute top-1/2 left-1/3 w-72 h-72 rounded-full bg-brand-gold/6 blur-3xl animate-float" style="animation-delay:1.5s"></div>

    <!-- Grid pattern overlay -->
    <svg class="absolute inset-0 w-full h-full opacity-[0.025]" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0D1117" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)"/>
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Content -->
      <div class="animate-fade-up">

        <!-- Trust Badge -->
        <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-white shadow-card border border-orange-100 mb-6">
          <div class="flex -space-x-1">
            {['🟠','🟡','🔵','🟢','🔴'].map(e => (
              <span class="w-5 h-5 rounded-full border-2 border-white text-[10px] grid place-items-center bg-gray-100">{e}</span>
            ))}
          </div>
          <span class="text-xs font-bold text-brand-dark">100+ Cities · 5 South Indian States</span>
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        </div>

        <!-- Headline -->
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-[1.05] text-brand-dark mb-5">
          {cityName ? (
            <>
              <span>Packers &amp; Movers</span><br/>
              <span>in </span>
              <span class="text-gradient">{cityName}</span>
            </>
          ) : title ? (
            <>
              <span set:html={title}></span>
            </>
          ) : (
            <>
              <span>South India's</span><br/>
              <span class="text-gradient">#1 Movers</span>
            </>
          )}
        </h1>

        <!-- Subheadline -->
        <p class="text-lg sm:text-xl text-brand-grey mb-8 max-w-lg leading-relaxed">
          {subtitle || (cityName
            ? `Trusted #1 packers and movers in ${cityName}, ${stateName || ''}. Safe, affordable & on-time relocation with 100% insurance & status tracking.`
            : 'Safe, affordable & on-time relocation across 100+ cities in South India. 100% insured, with order tracking, zero hidden charges.'
          )}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a
            href="#quote"
            class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full bg-gradient-to-r from-brand-orange to-brand-gold text-white font-bold text-base shadow-cta hover:shadow-glow hover:scale-[1.02] transition-all duration-200 btn-shine"
          >
            🚚 Book Free Quote
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a
            href="tel:+917731074075"
            class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full bg-white border-2 border-brand-orange/30 text-brand-dark font-bold text-base hover:border-brand-orange hover:bg-orange-50 transition-all duration-200"
            aria-label="Call PackersHub"
          >
            <svg class="w-4 h-4 text-brand-orange" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.36 11.36 0 003.58.57 1 1 0 011 1v3.5a1 1 0 01-1 1A17 17 0 013 5a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z"/></svg>
            +91 77310 74075
          </a>
        </div>

        <!-- Stats Row -->
        {showStats && (
          <div class="flex flex-wrap gap-6">
            {[
              { num: '100+', label: 'Cities Served', icon: '📍' },
              { num: '5', label: 'States Covered', icon: '🚚' },
              { num: '100%', label: 'Insured Moves', icon: '🛡️' },
              { num: '24/7', label: 'Support', icon: '🔔' },
            ].map(s => (
              <div class="text-center">
                <div class="text-xl">{s.icon}</div>
                <div class="font-display font-black text-2xl text-brand-dark stat-number">{s.num}</div>
                <div class="text-xs text-brand-grey font-medium">{s.label}</div>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Right: Visual Card -->
      <div class="relative animate-fade-up" style="animation-delay:.15s">
        <!-- Main image container -->
        <div class="relative rounded-3xl overflow-hidden shadow-2xl bg-gradient-to-br from-orange-100 to-sky-100 aspect-[4/3]">
          <img
            src="/hero.jpg"
            alt="PackersHub professional movers carefully packing and loading household items into a status-tracked truck"
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
            width="600"
            height="450"
            decoding="async"
            onerror="this.style.display='none';document.getElementById('hero-fallback-svg').style.display='block';"
          />
          <!-- v10.6.5 — Core Web Vitals fix: /hero.jpg was never present in public/,
               so this was 404-ing on every single page load (LCP element failing
               to render). Drop a real photo into public/hero.jpg to replace this
               permanently. Until then, this inline SVG renders instantly with
               zero extra HTTP request, so the hero never shows a broken image. -->
          <svg id="hero-fallback-svg" viewBox="0 0 600 400" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" style="display:none" aria-hidden="true">
            <rect width="600" height="400" rx="24" fill="#fff5f0"/>
            <rect x="60" y="180" width="300" height="140" rx="12" fill="#E8510A"/>
            <rect x="360" y="200" width="140" height="120" rx="10" fill="#C9961F"/>
            <rect x="370" y="210" width="60" height="45" rx="6" fill="#bfdbfe"/>
            <circle cx="140" cy="330" r="35" fill="#0D1117"/><circle cx="140" cy="330" r="18" fill="#4B5563"/>
            <circle cx="300" cy="330" r="35" fill="#0D1117"/><circle cx="300" cy="330" r="18" fill="#4B5563"/>
            <circle cx="440" cy="330" r="35" fill="#0D1117"/><circle cx="440" cy="330" r="18" fill="#4B5563"/>
            <rect x="80" y="140" width="70" height="50" rx="6" fill="#C9961F" opacity="0.9"/>
            <rect x="160" y="130" width="80" height="60" rx="6" fill="#fff" stroke="#E8510A" stroke-width="2" opacity="0.9"/>
            <rect x="250" y="150" width="60" height="40" rx="6" fill="#C9961F" opacity="0.8"/>
            <rect x="0" y="365" width="600" height="35" rx="0" fill="#e5e7eb"/>
            <rect x="50" y="378" width="80" height="8" rx="4" fill="#9ca3af" opacity="0.6"/>
            <rect x="200" y="378" width="80" height="8" rx="4" fill="#9ca3af" opacity="0.6"/>
            <rect x="350" y="378" width="80" height="8" rx="4" fill="#9ca3af" opacity="0.6"/>
            <rect x="500" y="378" width="60" height="8" rx="4" fill="#9ca3af" opacity="0.6"/>
            <circle cx="510" cy="80" r="30" fill="#E8510A" opacity="0.15"/>
            <path d="M510 55 C497 55 487 65 487 77 C487 93 510 115 510 115 C510 115 533 93 533 77 C533 65 523 55 510 55Z" fill="#E8510A"/>
            <circle cx="510" cy="77" r="8" fill="white"/>
            <text x="40" y="50" font-size="22" fill="#C9961F" opacity="0.7">★</text>
            <text x="550" y="130" font-size="16" fill="#C9961F" opacity="0.5">★</text>
            <text x="20" y="200" font-size="12" fill="#C9961F" opacity="0.4">★</text>
          </svg>
          <script is:inline>
            // Check immediately on each Astro page-load (covers ClientRouter
            // transitions) whether hero.jpg actually loaded; if not, the
            // onerror handler above already swapped to the SVG, but this
            // covers the case where the image was cached as a 404 response.
            document.addEventListener('astro:page-load', function () {
              var img = document.querySelector('img[src="/hero.jpg"]');
              if (img && img.complete && img.naturalWidth === 0) {
                img.style.display = 'none';
                var svg = document.getElementById('hero-fallback-svg');
                if (svg) svg.style.display = 'block';
              }
            });
          </script>
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/20 to-transparent"></div>
        </div>

        <!-- Floating trust badge — bottom left -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl p-4 shadow-2xl border border-gray-100 max-w-[200px]">
          <div class="flex items-center gap-2 mb-1">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-400 to-emerald-600 grid place-items-center text-white text-sm">✓</div>
            <div class="font-bold text-brand-dark text-xs">100% Insured</div>
          </div>
          <div class="text-[10px] text-brand-grey">Zero damage guarantee on all moves</div>
        </div>

        <!-- Floating coverage badge — top right -->
        <div class="absolute -top-4 -right-4 bg-white rounded-2xl p-3 shadow-xl border border-gray-100">
          <div class="text-center">
            <div class="font-display font-black text-2xl text-brand-dark">100+</div>
            <div class="text-brand-orange text-xs font-bold">Cities</div>
            <div class="text-[10px] text-brand-grey">South India</div>
          </div>
        </div>

        <!-- Floating status-tracking badge — right center -->
        <div class="absolute top-1/2 -right-5 -translate-y-1/2 bg-gradient-to-br from-accent-sky to-blue-700 text-white rounded-2xl p-3 shadow-xl">
          <div class="text-center">
            <div class="text-xl mb-0.5">📍</div>
            <div class="text-[10px] font-bold">Status</div>
            <div class="text-[9px] opacity-80">Tracked</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
