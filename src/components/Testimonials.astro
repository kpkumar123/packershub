---
// Testimonials.astro
//
// v9.1.1 — HONESTY FIX (original): removed 6 invented names/quotes/star
// ratings that were published as schema.org Review/Rating JSON-LD with
// no aggregateRating present — a Search-Console manual-action risk, and
// dishonest regardless of risk.
//
// v10.6.5 — this component now reads src/data/reviews.json. That file
// ships EMPTY and must only ever contain real, verifiable reviews (see
// src/data/REVIEWS_README.md for the exact format and the process for
// adding them from your Google Business Profile).
//
//   - Fewer than 5 real reviews on file -> same honest "illustrative
//     examples" mode as before. No Review/Rating/AggregateRating schema
//     is emitted, because a sample that small would make any published
//     average misleading.
//   - 5 or more real reviews on file -> Review + AggregateRating schema
//     is generated automatically from whatever is actually in the file.
//     Nothing here is hardcoded; the moment you add real reviews and
//     rebuild, this switches over on its own.
import reviews from '../data/reviews.json';

interface Review {
  name: string;
  rating: number;
  text: string;
  route?: string;
  date: string;
  source?: string;
}

const realReviews = (reviews as Review[]).filter(
  (r) => r && r.name && r.text && Number.isInteger(r.rating) && r.rating >= 1 && r.rating <= 5
);

const MIN_REVIEWS_TO_PUBLISH = 5;
const hasEnoughRealReviews = realReviews.length >= MIN_REVIEWS_TO_PUBLISH;

const avgRating = hasEnoughRealReviews
  ? Math.round((realReviews.reduce((sum, r) => sum + r.rating, 0) / realReviews.length) * 10) / 10
  : null;

const reviewSchema = hasEnoughRealReviews
  ? {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://www.packershub.in/#organization",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": avgRating,
        "reviewCount": realReviews.length,
        "bestRating": 5,
        "worstRating": 1,
      },
      "review": realReviews.slice(0, 20).map((r) => ({
        "@type": "Review",
        "author": { "@type": "Person", "name": r.name },
        "reviewRating": {
          "@type": "Rating",
          "ratingValue": r.rating,
          "bestRating": 5,
          "worstRating": 1,
        },
        "reviewBody": r.text,
        "datePublished": r.date,
      })),
    }
  : null;

// Illustrative fallback - unchanged from the honest v9.1.1 fix, used only
// when there isn't yet a large enough sample of real reviews.
const examples = [
  { move: 'Local home move, Hyderabad', note: 'Full-day 3BHK move handled start to finish, with the inventory check completed before the crew left.' },
  { move: 'Office relocation, Chennai → Coimbatore', note: 'Workstations and IT equipment moved over a weekend with no Monday downtime for the client.' },
  { move: 'Intercity move, Thiruvananthapuram → Kochi', note: 'Furniture disassembled, transported, and reassembled at the new home as part of the same booking.' },
];
---
<section class="py-20 bg-gradient-to-b from-orange-50/40 to-white" aria-labelledby="testimonials-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <span class="inline-block px-4 py-1.5 rounded-full bg-yellow-100 text-yellow-700 text-sm font-bold mb-4 uppercase tracking-wide">
        {hasEnoughRealReviews ? `${avgRating}★ from ${realReviews.length} Reviews` : 'How a Move Typically Goes'}
      </span>
      <h2 id="testimonials-heading" class="font-display text-4xl lg:text-5xl font-extrabold text-brand-dark mb-4">
        {hasEnoughRealReviews ? 'What Our Customers Say' : 'What a PackersHub Move Looks Like'}
      </h2>
      <p class="text-brand-grey max-w-xl mx-auto">
        {hasEnoughRealReviews
          ? `Real reviews from ${realReviews.length} verified PackersHub customers.`
          : 'Illustrative examples of the kind of service we aim to deliver — not verified customer quotes.'}
      </p>
    </div>

    {hasEnoughRealReviews ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {realReviews.slice(0, 9).map((r, i) => (
          <div class="p-8 rounded-3xl bg-white shadow-card border border-gray-100 card-lift reveal" style={`animation-delay:${i * .08}s`}>
            <div class="text-amber-500 mb-3 text-sm" aria-label={`${r.rating} out of 5 stars`}>{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</div>
            <p class="text-brand-grey leading-relaxed mb-6 text-sm">{r.text}</p>
            <div class="border-t border-gray-100 pt-4 flex items-center justify-between">
              <span class="text-xs font-bold text-brand-dark">{r.name}</span>
              {r.route && <span class="text-xs text-brand-orange font-bold bg-orange-50 px-2 py-1 rounded-full">{r.route}</span>}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {examples.map((r, i) => (
          <div class="p-8 rounded-3xl bg-white shadow-card border border-gray-100 card-lift reveal" style={`animation-delay:${i * .08}s`}>
            <div class="text-3xl mb-4" aria-hidden="true">📦</div>
            <p class="text-brand-grey leading-relaxed mb-6 text-sm">{r.note}</p>
            <div class="border-t border-gray-100 pt-4">
              <span class="text-xs text-brand-orange font-bold bg-orange-50 px-2 py-1 rounded-full">{r.move}</span>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
{reviewSchema && <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />}
