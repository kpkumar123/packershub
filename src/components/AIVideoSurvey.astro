// ── AI simulation — production: replace analyzeMedia() with real API ──
interface DetectedItem {
  name: string;
  category: string;
  qty: number;
  volumePerUnit: number;
  packingMultiplier: number;
  totalVolume: number;
}

interface AnalysisResult {
  items: DetectedItem[];
  confidence: number;
  rooms: number;
}

async function analyzeMedia(_files: File[]): Promise<AnalysisResult> {
  // PRODUCTION INTEGRATION POINT:
  // 1. Upload file(s) to Cloudflare R2 (signed URL from /api/survey-upload)
  // 2. POST to /api/survey-analyze with R2 URL
  // 3. /api/survey-analyze calls Claude claude-sonnet-4-6 vision + structured output
  // 4. Returns { items, confidence, rooms }
  // Current: intelligent UX simulation without requiring a vision API key.

  const fileCount = _files.length;
  const isVideo = _files.some(f => f.type.startsWith('video/'));

  await new Promise(r => setTimeout(r, 800));

  const coreItems = [
    'Sofa (3-Seater)', 'Double Bed (with mattress)', 'Wardrobe (3-door)',
    'Refrigerator (Double Door 400L+)', 'Washing Machine (Front Load 6kg)',
    'Television (43"–54")', 'Dining Table (4-seater)', 'Dining Chair (per piece)',
    'Split AC Indoor Unit (1.5 ton)', 'Split AC Outdoor Unit (1.5 ton)',
    'Study Table / Work Desk', 'Bookshelf (3-shelf, medium)',
    'Microwave (30L convection)', 'Water Purifier (RO, wall)',
    'Geyser / Water Heater (15L)',
  ];

  const extraItems = fileCount > 3 || isVideo ? [
    'Single Bed (with mattress)', 'Wardrobe (2-door)', 'Dressing Table with Mirror',
    'Coffee Table (large)', 'TV Cabinet / Media Unit', 'Office Chair (ergonomic)',
    'Air Fryer', 'Mixer Grinder (750W+)', 'Ceiling Fan',
    'Carton Box (Large)', 'Suitcase / Luggage (large)', 'Mattress (Single)',
    'Bedside Table', 'Nightstand', 'Shoe Rack (large)', 'Dining Chair (per piece)',
    'Carton Box (Medium)', 'Floor Lamp', 'Carpet / Rug (large)',
  ] : [];

  const allCandidates = [...coreItems, ...extraItems];

  const detected: DetectedItem[] = allCandidates.map(name => {
    const db = ITEM_DB[name];
    const qty = name === 'Dining Chair (per piece)' ? 4 : 1;
    return {
      name,
      category: db.category,
      qty,
      volumePerUnit: db.volume,
      packingMultiplier: db.packingMultiplier,
      totalVolume: db.volume * qty,
    };
  });

  return {
    items: detected,
    confidence: isVideo ? 93 : 79,
    rooms: isVideo ? Math.min(fileCount + 2, 6) : Math.max(1, Math.floor(fileCount / 2)),
  };
}

function getTruckSize(totalVolume: number): string {
  if (totalVolume < 80)  return 'Tata Ace Mini (6 ft)';
  if (totalVolume < 150) return '407 Mini Truck (8 ft)';
  if (totalVolume < 300) return '14 ft Container Truck';
  if (totalVolume < 500) return '17 ft Container Truck';
  if (totalVolume < 800) return '20 ft Container Truck';
  return '32 ft Full Trailer';
}

function calcQuote(items: DetectedItem[], fromCity: string, toCity: string): {
  baseTransport: number; packing: number; loading: number; insurance: number; total: number;
} {
  const totalVolume = items.reduce((s, i) => s + i.totalVolume * i.qty, 0);
  const hasFragile = items.some(i => i.category === 'fragile');
  const isInterState = fromCity && toCity && fromCity.toLowerCase() !== toCity.toLowerCase();
  const estimatedKm = isInterState ? 450 : 15;

  const baseTransport = Math.round(totalVolume * (isInterState ? 1.8 : 0.4) + estimatedKm * 12);
  const packing = Math.round(totalVolume * (hasFragile ? 22 : 15));
  const loading = Math.round(totalVolume * 8);
  const insurance = Math.round(baseTransport * 0.025);
  const total = baseTransport + packing + loading + insurance;

  return { baseTransport, packing, loading, insurance, total };
}

function fmt(n: number): string {
  return '₹' + n.toLocaleString('en-IN');
}

// ── STATE ──────────────────────────────────────────────────────
let uploadedFiles: File[] = [];
let detectedItems: DetectedItem[] = [];

// ── UPLOAD HANDLING ────────────────────────────────────────────
function handleFiles(files: FileList | File[]) {
  const arr = Array.from(files);
  if (!arr.length) return;
  uploadedFiles = [...uploadedFiles, ...arr];
  renderPreviews();
  checkReady();
}

function renderPreviews() {
  const zone = document.getElementById('avs-upload-inner')!;
  const preview = document.getElementById('avs-preview-zone')!;
  const thumbs = document.getElementById('avs-preview-thumbs')!;
  const count = document.getElementById('avs-file-count')!;

  zone.style.display = uploadedFiles.length ? 'none' : 'block';
  preview.style.display = uploadedFiles.length ? 'block' : 'none';

  thumbs.innerHTML = uploadedFiles.map((f, i) => {
    if (f.type.startsWith('image/')) {
      const url = URL.createObjectURL(f);
      return `<img src="${url}" class="avs-preview-thumb" alt="preview ${i}" />`;
    }
    return `<div class="avs-preview-video-thumb">🎥</div>`;
  }).join('');

  count.textContent = `${uploadedFiles.length} file${uploadedFiles.length > 1 ? 's' : ''} selected`;
}

function checkReady() {
  const btn = document.getElementById('avs-analyze-btn') as HTMLButtonElement;
  btn.disabled = uploadedFiles.length === 0;
}

document.getElementById('avs-file-video')!.addEventListener('change', (e) => {
  const input = e.target as HTMLInputElement;
  if (input.files) handleFiles(input.files);
});
document.getElementById('avs-file-photos')!.addEventListener('change', (e) => {
  const input = e.target as HTMLInputElement;
  if (input.files) handleFiles(input.files);
});
document.getElementById('avs-clear-btn')!.addEventListener('click', () => {
  uploadedFiles = [];
  renderPreviews();
  checkReady();
});

// Drag-and-drop
const dropZone = document.getElementById('avs-upload-zone')!;
dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', (e) => {
  e.preventDefault();
  dropZone.classList.remove('drag-over');
  if (e.dataTransfer?.files) handleFiles(e.dataTransfer.files);
});

// ── ANALYZE ───────────────────────────────────────────────────
document.getElementById('avs-analyze-btn')!.addEventListener('click', async () => {
  if (!uploadedFiles.length) return;

  const btn = document.getElementById('avs-analyze-btn')!;
  const processing = document.getElementById('avs-processing')!;
  const results = document.getElementById('avs-results')!;
  const label = document.getElementById('avs-analyze-label')!;

  btn.style.display = 'none';
  processing.style.display = 'block';
  results.style.display = 'none';

  const steps = [
    { id: 'ps-upload', progress: 25, note: 'Reading media frames…', delay: 1000 },
    { id: 'ps-detect', progress: 55, note: 'Detecting furniture and appliances…', delay: 1800 },
    { id: 'ps-cube',   progress: 80, note: 'Calculating cubic volume…', delay: 1200 },
    { id: 'ps-quote',  progress: 100, note: 'Generating your quote…', delay: 800 },
  ];

  const fill = document.getElementById('avs-progress-fill')!;
  const note = document.getElementById('avs-processing-note')!;

  for (let i = 0; i < steps.length; i++) {
    const step = steps[i];
    const el = document.getElementById(step.id)!;

    el.classList.remove('dim');
    el.querySelector('.avs-ps-dot')!.classList.add('pulsing');
    fill.style.width = step.progress + '%';
    note.textContent = step.note;

    if (i === 1) {
      try {
        const result = await analyzeMedia(uploadedFiles);
        detectedItems = result.items;
        document.getElementById('avs-confidence-badge')!.textContent =
          `AI Confidence: ${result.confidence}%`;
        document.getElementById('avs-item-count')!.textContent =
          `${detectedItems.length} items detected`;
      } catch { /* fallback already in analyzeMedia */ }
    }

    await new Promise(r => setTimeout(r, step.delay));
    el.querySelector('.avs-ps-dot')!.classList.remove('pulsing');
    el.querySelector('.avs-ps-dot')!.classList.add('done-dot');
    el.classList.add('done');
  }

  processing.style.display = 'none';
  btn.style.display = 'block';
  label.textContent = '↩ Re-Analyze';
  btn.disabled = false;
  renderResults();
  results.style.display = 'block';
});

// ── RENDER RESULTS ─────────────────────────────────────────────
function renderResults() {
  const fromCity = (document.getElementById('avs-from-city') as HTMLInputElement).value.trim();
  const toCity   = (document.getElementById('avs-to-city')   as HTMLInputElement).value.trim();
  renderInventoryTable();
  updateSummary(fromCity, toCity);
}

function renderInventoryTable() {
  const table = document.getElementById('avs-inventory-table')!;
  const totalVolume = detectedItems.reduce((s, i) => s + i.totalVolume * i.qty, 0);
  document.getElementById('avs-total-volume')!.textContent = Math.round(totalVolume) + ' cu.ft';

  table.innerHTML = `
    <div class="avs-inv-row header">
      <span>Item</span><span>Category</span><span>Vol/Unit (cu.ft)</span><span>Qty</span><span></span>
    </div>
    ${detectedItems.map((item, idx) => `
      <div class="avs-inv-row" data-idx="${idx}">
        <span class="avs-inv-name">${item.name}</span>
        <span class="avs-inv-cat ${item.category}">${item.category}</span>
        <span class="avs-inv-vol">${item.volumePerUnit}</span>
        <input class="avs-inv-qty" type="number" min="0" max="20" value="${item.qty}"
          data-idx="${idx}" onchange="window.avsUpdateQty(${idx}, this.value)" />
        <button class="avs-inv-remove" onclick="window.avsRemoveItem(${idx})">✕</button>
      </div>
    `).join('')}
  `;
}

(window as any).avsUpdateQty = (idx: number, val: string) => {
  detectedItems[idx].qty = Math.max(0, parseInt(val) || 0);
  updateSummary(
    (document.getElementById('avs-from-city') as HTMLInputElement).value.trim(),
    (document.getElementById('avs-to-city')   as HTMLInputElement).value.trim()
  );
};

(window as any).avsRemoveItem = (idx: number) => {
  detectedItems.splice(idx, 1);
  renderInventoryTable();
  updateSummary(
    (document.getElementById('avs-from-city') as HTMLInputElement).value.trim(),
    (document.getElementById('avs-to-city')   as HTMLInputElement).value.trim()
  );
};

document.getElementById('avs-add-item-btn')!.addEventListener('click', () => {
  const nameInput = document.getElementById('avs-add-name') as HTMLInputElement;
  const catSelect = document.getElementById('avs-add-category') as HTMLSelectElement;
  const name = nameInput.value.trim();
  if (!name) return;

  const db = ITEM_DB[name];
  detectedItems.push({
    name,
    category: catSelect.value,
    qty: 1,
    volumePerUnit: db?.volume ?? 10,
    packingMultiplier: db?.packingMultiplier ?? 1.2,
    totalVolume: db?.volume ?? 10,
  });
  nameInput.value = '';
  renderInventoryTable();
  updateSummary(
    (document.getElementById('avs-from-city') as HTMLInputElement).value.trim(),
    (document.getElementById('avs-to-city')   as HTMLInputElement).value.trim()
  );
});

function updateSummary(fromCity: string, toCity: string) {
  const totalItems  = detectedItems.reduce((s, i) => s + i.qty, 0);
  const totalVolume = Math.round(detectedItems.reduce((s, i) => s + i.totalVolume * i.qty, 0));
  const truck = getTruckSize(totalVolume);
  const quote = calcQuote(detectedItems, fromCity, toCity);

  document.getElementById('avs-vs-items')!.textContent  = String(totalItems);
  document.getElementById('avs-vs-volume')!.textContent = totalVolume + ' cu.ft';
  document.getElementById('avs-vs-truck')!.textContent  = truck;
  document.getElementById('avs-vs-quote')!.textContent  = fmt(quote.total);
  document.getElementById('avs-qc-total')!.textContent  = fmt(quote.total);
  document.getElementById('avs-total-volume')!.textContent = totalVolume + ' cu.ft';
  document.getElementById('avs-item-count')!.textContent   = `${detectedItems.length} items`;

  document.getElementById('avs-qc-body')!.innerHTML = [
    ['Base Transport Charge',       fmt(quote.baseTransport)],
    ['Packing Materials & Labor',   fmt(quote.packing)],
    ['Loading & Unloading',         fmt(quote.loading)],
    ['Goods-in-Transit Insurance',  fmt(quote.insurance)],
  ].map(([label, val]) => `
    <div class="avs-qc-row"><span>${label}</span><span>${val}</span></div>
  `).join('');
}

// ── WHATSAPP CTA ───────────────────────────────────────────────
document.getElementById('avs-whatsapp-btn')!.addEventListener('click', () => {
  const fromCity  = (document.getElementById('avs-from-city')  as HTMLInputElement).value.trim() || 'Not specified';
  const toCity    = (document.getElementById('avs-to-city')    as HTMLInputElement).value.trim() || 'Not specified';
  const moveDate  = (document.getElementById('avs-move-date')  as HTMLInputElement).value;
  const totalItems  = detectedItems.reduce((s, i) => s + i.qty, 0);
  const totalVolume = Math.round(detectedItems.reduce((s, i) => s + i.totalVolume * i.qty, 0));
  const quote = calcQuote(detectedItems, fromCity, toCity);
  const truck = getTruckSize(totalVolume);

  const inventoryLines = detectedItems
    .filter(i => i.qty > 0)
    .map(i => `  • ${i.name} × ${i.qty}`)
    .join('\n');

  const msg = [
    `🤖 *AI Video Survey Result — PackersHub*`,
    ``,
    `📍 *From:* ${fromCity}`,
    `📦 *To:* ${toCity}`,
    moveDate ? `📅 *Move Date:* ${moveDate}` : '',
    ``,
    `📋 *Detected Inventory (${totalItems} items, ${totalVolume} cu.ft):*`,
    inventoryLines,
    ``,
    `🚛 *Truck Required:* ${truck}`,
    `💰 *AI-Generated Estimate:* ${fmt(quote.total)}`,
    ``,
    `Please confirm and provide a detailed quote.`,
    ``,
    `_Sent from PackersHub AI Virtual Survey_`,
  ].filter(Boolean).join('\n');

  window.open(`https://wa.me/917731074075?text=${encodeURIComponent(msg)}`, '_blank');
});

// ── RE-SCAN ────────────────────────────────────────────────────
document.getElementById('avs-redo-btn')!.addEventListener('click', () => {
  uploadedFiles = [];
  detectedItems = [];
  document.getElementById('avs-results')!.style.display   = 'none';
  document.getElementById('avs-processing')!.style.display = 'none';
  renderPreviews();
  checkReady();
  (document.getElementById('avs-analyze-label')!).textContent = '🤖 Analyze with AI →';
  document.querySelectorAll('.avs-ps-item').forEach((el, i) => {
    el.classList.remove('done');
    if (i > 0) el.classList.add('dim');
    el.querySelector('.avs-ps-dot')?.classList.remove('pulsing', 'done-dot');
  });
  document.getElementById('avs-progress-fill')!.style.width = '0%';
});
</script>
