---
// AIVideoSurvey.astro — AI-Powered Virtual Survey Component
// PackersHub v10.5 — Astro 7.0.3 compatible
// USAGE: <AIVideoSurvey bookingOnly={true} /> → renders only on /booking page
// City landing pages must NOT import this component.
// Props:
//   bookingOnly?: boolean  — if true, component renders; if false/undefined, renders nothing
//   fromCity?: string      — pre-fill from city (passed from booking page context)
//   toCity?: string        — pre-fill to city

interface Props {
  bookingOnly?: boolean;
  fromCity?: string;
  toCity?: string;
}

const { bookingOnly = false, fromCity = '', toCity = '' } = Astro.props;

// Guard: only render on /booking page
if (!bookingOnly) return;
---

<section id="ai-video-survey" class="avs-wrapper">
  <div class="avs-header">
    <div class="avs-header-badge">🤖 AI-Powered</div>
    <h2 class="avs-title">Virtual Home Survey</h2>
    <p class="avs-subtitle">
      Upload a short video or photos of your home — our AI instantly identifies every item,
      builds your inventory list, and generates a precise shifting quote. No guesswork.
    </p>
    <div class="avs-trust-row">
      <span class="avs-trust-chip">⚡ Results in 60 seconds</span>
      <span class="avs-trust-chip">🔒 Your media is private</span>
      <span class="avs-trust-chip">📦 280+ item types</span>
      <span class="avs-trust-chip">✅ More accurate than dropdown</span>
    </div>
  </div>

  <!-- Upload Zone -->
  <div class="avs-upload-zone" id="avs-upload-zone">
    <div class="avs-upload-inner" id="avs-upload-inner">
      <div class="avs-upload-icon">🎥</div>
      <p class="avs-upload-main">Drop your video or photos here</p>
      <p class="avs-upload-sub">MP4, MOV, AVI · JPG, PNG · Max 100 MB · Walk through each room slowly</p>
      <div class="avs-upload-btns">
        <label class="avs-btn-upload" for="avs-file-video">
          📹 Upload Video
          <input type="file" id="avs-file-video" accept="video/*" style="display:none" />
        </label>
        <label class="avs-btn-upload secondary" for="avs-file-photos">
          📷 Upload Photos
          <input type="file" id="avs-file-photos" accept="image/*" multiple style="display:none" />
        </label>
      </div>
      <p class="avs-tip">💡 Tip: Walk room-by-room, 10–30 seconds per room. Open wardrobes, show appliances.</p>
    </div>

    <!-- Preview after upload -->
    <div class="avs-preview-zone" id="avs-preview-zone" style="display:none">
      <div class="avs-preview-thumbs" id="avs-preview-thumbs"></div>
      <div class="avs-preview-info">
        <span id="avs-file-count">0 files selected</span>
        <button class="avs-btn-clear" id="avs-clear-btn">✕ Clear</button>
      </div>
    </div>
  </div>

  <!-- Route context (needed for distance-based pricing) -->
  <div class="avs-context-row" id="avs-context-row">
    <div class="avs-ctx-field">
      <label class="avs-label">From City</label>
      <input type="text" class="avs-input" id="avs-from-city" placeholder="e.g. Hyderabad" value={fromCity} />
    </div>
    <div class="avs-ctx-arrow">→</div>
    <div class="avs-ctx-field">
      <label class="avs-label">To City</label>
      <input type="text" class="avs-input" id="avs-to-city" placeholder="e.g. Bengaluru" value={toCity} />
    </div>
    <div class="avs-ctx-field avs-ctx-date">
      <label class="avs-label">Move Date</label>
      <input type="date" class="avs-input" id="avs-move-date" />
    </div>
  </div>

  <!-- Analyze Button -->
  <button class="avs-analyze-btn" id="avs-analyze-btn" disabled>
    <span id="avs-analyze-label">🤖 Analyze with AI →</span>
  </button>

  <!-- Processing State -->
  <div class="avs-processing" id="avs-processing" style="display:none">
    <div class="avs-process-steps">
      <div class="avs-ps-item" id="ps-upload">
        <div class="avs-ps-dot pulsing"></div>
        <span>Uploading media…</span>
      </div>
      <div class="avs-ps-item dim" id="ps-detect">
        <div class="avs-ps-dot"></div>
        <span>Detecting furniture & items…</span>
      </div>
      <div class="avs-ps-item dim" id="ps-cube">
        <div class="avs-ps-dot"></div>
        <span>Calculating cube volume…</span>
      </div>
      <div class="avs-ps-item dim" id="ps-quote">
        <div class="avs-ps-dot"></div>
        <span>Generating quote…</span>
      </div>
    </div>
    <div class="avs-progress-bar">
      <div class="avs-progress-fill" id="avs-progress-fill" style="width:0%"></div>
    </div>
    <p class="avs-processing-note" id="avs-processing-note">This takes about 30–60 seconds</p>
  </div>

  <!-- Results -->
  <div class="avs-results" id="avs-results" style="display:none">

    <!-- Inventory Table -->
    <div class="avs-results-header">
      <h3 class="avs-results-title">🏠 Detected Inventory</h3>
      <div class="avs-results-meta">
        <span id="avs-item-count">0 items</span>
        <span class="avs-sep">·</span>
        <span id="avs-total-volume">0 cu.ft</span>
        <span class="avs-sep">·</span>
        <span id="avs-confidence-badge">AI Confidence: —</span>
      </div>
    </div>

    <div class="avs-inventory-table" id="avs-inventory-table">
      <!-- populated by JS -->
    </div>

    <!-- Add item manually -->
    <div class="avs-add-item-row">
      <input type="text" class="avs-input" id="avs-add-name" placeholder="Add missed item (e.g. Washing Machine)" />
      <select class="avs-select" id="avs-add-category">
        <option value="appliance">Appliance</option>
        <option value="furniture">Furniture</option>
        <option value="fragile">Fragile</option>
        <option value="other">Other</option>
      </select>
      <button class="avs-btn-add" id="avs-add-item-btn">+ Add</button>
    </div>

    <!-- Volume Summary -->
    <div class="avs-volume-summary">
      <div class="avs-vs-row">
        <div class="avs-vs-item">
          <span class="avs-vs-label">Total Items</span>
          <span class="avs-vs-val" id="avs-vs-items">—</span>
        </div>
        <div class="avs-vs-item">
          <span class="avs-vs-label">Total Volume</span>
          <span class="avs-vs-val" id="avs-vs-volume">—</span>
        </div>
        <div class="avs-vs-item">
          <span class="avs-vs-label">Truck Size Needed</span>
          <span class="avs-vs-val" id="avs-vs-truck">—</span>
        </div>
        <div class="avs-vs-item highlight">
          <span class="avs-vs-label">Estimated Quote</span>
          <span class="avs-vs-val gold" id="avs-vs-quote">—</span>
        </div>
      </div>
    </div>

    <!-- Quote Breakdown -->
    <div class="avs-quote-card">
      <div class="avs-qc-header">
        <span>💰 Your AI-Generated Quote</span>
        <span class="avs-qc-tag">Volume-Based Pricing</span>
      </div>
      <div class="avs-qc-body" id="avs-qc-body">
        <!-- populated by JS -->
      </div>
      <div class="avs-qc-total">
        <span>Total Estimate (All-Inclusive)</span>
        <span class="avs-qc-total-val" id="avs-qc-total">₹—</span>
      </div>
    </div>

    <!-- CTA Row -->
    <div class="avs-cta-row">
      <button class="avs-btn-whatsapp" id="avs-whatsapp-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Book This Quote via WhatsApp
      </button>
      <a href="tel:+917731074075" class="avs-btn-call">📞 Call & Confirm</a>
      <button class="avs-btn-redo" id="avs-redo-btn">↩ Re-Scan</button>
    </div>
  </div>
</section>

<style>
.avs-wrapper {
  background: linear-gradient(135deg, #0f172a 0%, #1a2744 100%);
  border-radius: 20px;
  padding: 2rem;
  box-shadow: 0 25px 60px rgba(0,0,0,0.35);
  position: relative;
  overflow: hidden;
}
.avs-wrapper::before {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(139,92,246,0.15), transparent 70%);
  pointer-events: none;
}

/* Header */
.avs-header { text-align: center; margin-bottom: 2rem; }
.avs-header-badge {
  display: inline-block;
  background: linear-gradient(135deg, #7c3aed, #4f46e5);
  color: #fff;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border-radius: 20px;
  padding: 4px 14px;
  margin-bottom: 10px;
}
.avs-title { color: #fff; font-size: 1.5rem; font-weight: 800; margin: 0 0 8px; }
.avs-subtitle { color: rgba(255,255,255,0.6); font-size: 0.875rem; line-height: 1.6; margin: 0 0 1rem; max-width: 520px; margin-left: auto; margin-right: auto; }
.avs-trust-row { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
.avs-trust-chip {
  background: rgba(139,92,246,0.12);
  border: 1px solid rgba(139,92,246,0.3);
  border-radius: 20px;
  padding: 4px 12px;
  color: #c4b5fd;
  font-size: 0.72rem;
  font-weight: 600;
}

/* Upload Zone */
.avs-upload-zone {
  border: 2px dashed rgba(139,92,246,0.4);
  border-radius: 16px;
  background: rgba(139,92,246,0.05);
  transition: all 0.3s;
  margin-bottom: 1.25rem;
}
.avs-upload-zone.drag-over {
  border-color: #8b5cf6;
  background: rgba(139,92,246,0.12);
}
.avs-upload-inner {
  padding: 2rem 1.5rem;
  text-align: center;
}
.avs-upload-icon { font-size: 2.5rem; margin-bottom: 12px; }
.avs-upload-main { color: #fff; font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
.avs-upload-sub { color: rgba(255,255,255,0.45); font-size: 0.75rem; margin: 0 0 1.25rem; }
.avs-upload-btns { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-bottom: 1rem; }
.avs-btn-upload {
  background: linear-gradient(135deg, #7c3aed, #6d28d9);
  color: #fff;
  font-weight: 700;
  font-size: 0.85rem;
  border: none;
  border-radius: 10px;
  padding: 10px 20px;
  cursor: pointer;
  transition: all 0.2s;
  display: inline-block;
}
.avs-btn-upload:hover { background: linear-gradient(135deg, #8b5cf6, #7c3aed); transform: translateY(-1px); }
.avs-btn-upload.secondary {
  background: rgba(139,92,246,0.15);
  border: 1.5px solid rgba(139,92,246,0.4);
  color: #c4b5fd;
}
.avs-btn-upload.secondary:hover { background: rgba(139,92,246,0.25); }
.avs-tip { color: rgba(255,255,255,0.4); font-size: 0.72rem; font-style: italic; }

/* Preview */
.avs-preview-zone { padding: 1rem 1.5rem; }
.avs-preview-thumbs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 10px; }
.avs-preview-thumb {
  width: 64px; height: 64px;
  border-radius: 8px;
  object-fit: cover;
  border: 2px solid rgba(139,92,246,0.4);
}
.avs-preview-video-thumb {
  width: 64px; height: 64px;
  background: rgba(139,92,246,0.2);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  border: 2px solid rgba(139,92,246,0.4);
}
.avs-preview-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: rgba(255,255,255,0.6);
  font-size: 0.8rem;
}
.avs-btn-clear {
  background: rgba(239,68,68,0.15);
  border: 1px solid rgba(239,68,68,0.3);
  color: #fca5a5;
  border-radius: 6px;
  padding: 4px 10px;
  font-size: 0.72rem;
  cursor: pointer;
}

/* Context row */
.avs-context-row {
  display: grid;
  grid-template-columns: 1fr auto 1fr 1fr;
  gap: 12px;
  align-items: end;
  margin-bottom: 1.25rem;
}
.avs-ctx-arrow { color: #8b5cf6; font-size: 1.25rem; font-weight: 700; padding-bottom: 10px; text-align: center; }
.avs-label { display: block; color: rgba(255,255,255,0.6); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
.avs-input, .avs-select {
  width: 100%;
  background: rgba(255,255,255,0.07);
  border: 1.5px solid rgba(255,255,255,0.12);
  border-radius: 10px;
  padding: 0.6rem 0.85rem;
  color: #fff;
  font-size: 0.85rem;
  outline: none;
  font-family: inherit;
  box-sizing: border-box;
  transition: border-color 0.2s;
}
.avs-input:focus, .avs-select:focus { border-color: #8b5cf6; }
.avs-input::placeholder { color: rgba(255,255,255,0.3); }
.avs-select option { background: #1e3a8a; }

/* Analyze Button */
.avs-analyze-btn {
  width: 100%;
  background: linear-gradient(135deg, #7c3aed, #4f46e5);
  color: #fff;
  font-weight: 800;
  font-size: 1rem;
  border: none;
  border-radius: 14px;
  padding: 1rem 1.5rem;
  cursor: pointer;
  transition: all 0.2s;
  margin-bottom: 1.5rem;
  box-shadow: 0 6px 20px rgba(124,58,237,0.4);
}
.avs-analyze-btn:hover:not(:disabled) {
  background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(124,58,237,0.5);
}
.avs-analyze-btn:disabled { opacity: 0.35; cursor: not-allowed; }

/* Processing */
.avs-processing { margin-bottom: 1.5rem; }
.avs-process-steps { display: flex; flex-direction: column; gap: 12px; margin-bottom: 1.25rem; }
.avs-ps-item {
  display: flex;
  align-items: center;
  gap: 12px;
  color: rgba(255,255,255,0.8);
  font-size: 0.875rem;
  font-weight: 600;
  transition: opacity 0.3s;
}
.avs-ps-item.dim { opacity: 0.35; }
.avs-ps-item.done { color: #4ade80; }
.avs-ps-dot {
  width: 12px; height: 12px;
  border-radius: 50%;
  background: rgba(139,92,246,0.4);
  flex-shrink: 0;
}
.avs-ps-dot.pulsing {
  background: #8b5cf6;
  animation: avsPulse 1s ease-in-out infinite;
}
.avs-ps-dot.done-dot { background: #4ade80; }
@keyframes avsPulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(139,92,246,0.4); }
  50% { box-shadow: 0 0 0 6px rgba(139,92,246,0); }
}
.avs-progress-bar {
  height: 6px;
  background: rgba(255,255,255,0.08);
  border-radius: 99px;
  overflow: hidden;
  margin-bottom: 8px;
}
.avs-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #7c3aed, #8b5cf6);
  border-radius: 99px;
  transition: width 0.6s cubic-bezier(0.34,1.56,0.64,1);
}
.avs-processing-note { color: rgba(255,255,255,0.4); font-size: 0.75rem; text-align: center; }

/* Results */
.avs-results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 1rem;
}
.avs-results-title { color: #fff; font-size: 1.1rem; font-weight: 700; margin: 0; }
.avs-results-meta { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.55); font-size: 0.8rem; }
.avs-sep { color: rgba(255,255,255,0.25); }
.avs-confidence-badge { color: #a78bfa; font-weight: 700; }

/* Inventory Table */
.avs-inventory-table {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 1rem;
}
.avs-inv-row {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr auto;
  gap: 8px;
  align-items: center;
  padding: 10px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  transition: background 0.15s;
}
.avs-inv-row:last-child { border-bottom: none; }
.avs-inv-row:hover { background: rgba(255,255,255,0.03); }
.avs-inv-row.header {
  background: rgba(139,92,246,0.1);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: rgba(255,255,255,0.5);
  padding: 8px 14px;
}
.avs-inv-name { color: #fff; font-size: 0.82rem; font-weight: 600; }
.avs-inv-cat {
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  padding: 2px 8px;
  border-radius: 10px;
  width: fit-content;
}
.avs-inv-cat.furniture { background: rgba(59,130,246,0.2); color: #93c5fd; }
.avs-inv-cat.appliance { background: rgba(245,158,11,0.2); color: #fcd34d; }
.avs-inv-cat.fragile { background: rgba(239,68,68,0.2); color: #fca5a5; }
.avs-inv-cat.other { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.6); }
.avs-inv-vol { color: rgba(255,255,255,0.7); font-size: 0.8rem; }
.avs-inv-qty {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 6px;
  padding: 3px 8px;
  color: #fff;
  font-size: 0.8rem;
  width: 50px;
  text-align: center;
  outline: none;
}
.avs-inv-remove {
  background: none;
  border: none;
  color: rgba(239,68,68,0.6);
  cursor: pointer;
  font-size: 1rem;
  padding: 2px 6px;
  border-radius: 4px;
  transition: color 0.2s;
}
.avs-inv-remove:hover { color: #ef4444; }

/* Add Item Row */
.avs-add-item-row {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 8px;
  margin-bottom: 1.25rem;
}
.avs-btn-add {
  background: rgba(139,92,246,0.2);
  border: 1.5px solid rgba(139,92,246,0.4);
  color: #c4b5fd;
  border-radius: 10px;
  padding: 0.6rem 1rem;
  font-size: 0.82rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}
.avs-btn-add:hover { background: rgba(139,92,246,0.35); }

/* Volume Summary */
.avs-volume-summary {
  background: rgba(139,92,246,0.08);
  border: 1px solid rgba(139,92,246,0.2);
  border-radius: 14px;
  padding: 1.25rem;
  margin-bottom: 1.25rem;
}
.avs-vs-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}
.avs-vs-item { text-align: center; }
.avs-vs-label { display: block; color: rgba(255,255,255,0.5); font-size: 0.68rem; font-weight: 700; text-transform: uppercase; margin-bottom: 4px; }
.avs-vs-val { color: #fff; font-size: 1rem; font-weight: 800; }
.avs-vs-val.gold { color: #f59e0b; font-size: 1.15rem; }
.avs-vs-item.highlight .avs-vs-label { color: #f59e0b; }

/* Quote Card */
.avs-quote-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  overflow: hidden;
  margin-bottom: 1.25rem;
}
.avs-qc-header {
  background: rgba(139,92,246,0.12);
  padding: 12px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: rgba(255,255,255,0.8);
  font-size: 0.875rem;
  font-weight: 700;
}
.avs-qc-tag {
  background: rgba(139,92,246,0.25);
  color: #c4b5fd;
  border-radius: 20px;
  padding: 3px 10px;
  font-size: 0.68rem;
  font-weight: 700;
}
.avs-qc-body { padding: 0 16px; }
.avs-qc-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
